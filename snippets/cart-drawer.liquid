  /* ---------- Parse HulkApps option selects from fetched product-page HTML ---------- */
  function parseOpts(html) {
    var doc = new DOMParser().parseFromString(html, 'text/html');

    /* Try known HulkApps container selectors; fall back to full body */
    var root = (
      doc.querySelector('#hulk_form') ||
      doc.querySelector('.hulk-app-form') ||
      doc.querySelector('.hulkApps-form') ||
      doc.querySelector('.hulk_product_options') ||
      doc.querySelector('[id*="hulk_form"]') ||
      doc.querySelector('[class*="hulk-option"]') ||
      doc.body
    );

    var results = [];
    Array.from(root.querySelectorAll('select')).forEach(function (sel) {
      /* Skip quantity / variant-id selects */
      var nm = sel.getAttribute('name') || '';
      if (/^(quantity|id)$/.test(nm)) return;

      /* Derive property name */
      var propMatch = nm.match(/properties\[(.+?)\]/);
      var propName = propMatch ? propMatch[1].trim() : '';

      if (!propName) {
        /* Walk up to find a label sibling */
        var node = sel.parentElement;
        for (var i = 0; i < 5 && node; i++, node = node.parentElement) {
          var lbl = node.querySelector('label');
          if (lbl && !lbl.contains(sel)) {
            propName = lbl.textContent.replace(/\s*:?\s*$/, '').trim();
            break;
          }
        }
      }
      if (!propName) return;

      var opts = Array.from(sel.options).map(function (o) {
        return { value: o.value, text: o.text.trim() };
      });

      /* Must have at least 2 real options */
      if (opts.length < 2) return;

      results.push({ label: propName, propName: propName, opts: opts });
    });

    return results;
  }

  /* ---------- Render form into panel ---------- */
  function showBtnRow(panel) {
    var row = panel.querySelector('.cart-acc-btn-row');
    if (row) row.removeAttribute('hidden');
  }

  function renderForm(panel, opts, currentProps) {
    try { panel.dataset.baseProps = JSON.stringify(currentProps); } catch(e) {}
    var wrap = panel.querySelector('.cart-acc-form-wrap');
    if (!wrap) return;

    if (!opts || !opts.length) {
      wrap.innerHTML = '<p class="cart-acc-panel-empty">No accessories found for this product.</p>';
      return;
    }

    var html = '';
    opts.forEach(function (opt) {
      var cur = currentProps[opt.propName] || '';
      /* Does the product's own option list already start with a placeholder
         (e.g. "Choose a selection…", "None", "No line set")? */
      var first = opt.opts[0] || {};
      var hasPlaceholder = (first.value === '') || /^\s*(choose|select|none|no\b)/i.test(first.text || '');
      html += '<div class="cart-acc-form-group">'
        + '<label class="cart-acc-form-label">' + opt.label + '</label>'
        + '<select class="cart-acc-form-select" data-prop-name="' + opt.propName.replace(/"/g, '&quot;') + '">';
      /* Synthesize a placeholder when the product list lacks one, so an accessory
         that isn't on the line never defaults to showing — and silently re-adding
         on Save — a real (priced) option. */
      if (!hasPlaceholder) {
        html += '<option value=""' + (cur ? '' : ' selected') + '>Choose a selection…</option>';
      }
      opt.opts.forEach(function (o) {
        var sel = (cur && (o.value === cur || o.text === cur)) ? ' selected' : '';
        html += '<option value="' + o.value.replace(/"/g, '&quot;') + '"' + sel + '>' + o.text + '</option>';
      });
      html += '</select></div>';
    });
    wrap.innerHTML = html;
    /* Prevent select change events from bubbling to cart-drawer-items and triggering updateQuantity */
    wrap.addEventListener('change', function(e) { e.stopPropagation(); });
    showBtnRow(panel);
  }

  /* ---------- Pre-fetch product options (called early, no UI interaction needed) ---------- */
  function prefetchHandle(handle, accType) {
    if (!handle) return;
    /* Resolve accType from toggle if not supplied */
    if (!accType) {
      var tog = document.querySelector('.cart-acc-toggle[data-handle="' + handle + '"]');
      if (tog) accType = tog.dataset.accType;
    }
    /* Use hardcoded dictionary when type is known — no network request needed */
    if (accType && _ACC_OPTS_BY_TYPE[accType]) {
      if (!Array.isArray(OPT_CACHE[handle])) OPT_CACHE[handle] = _ACC_OPTS_BY_TYPE[accType];
      preRenderPanels(handle);
      return;
    }
    if (OPT_CACHE[handle] !== undefined) {
      /* Cache already set — still pre-render any panels added by a cart re-render */
      if (Array.isArray(OPT_CACHE[handle])) preRenderPanels(handle);
      return;
    }
    OPT_CACHE[handle] = null; /* mark as in-flight */
    fetch('/products/' + handle)
      .then(function (r) { return r.text(); })
      .then(function (html) { OPT_CACHE[handle] = parseOpts(html); preRenderPanels(handle); })
      .catch(function () { OPT_CACHE[handle] = []; });
  }

  function prefetchAll() {
    document.querySelectorAll('.cart-acc-toggle[data-handle]').forEach(function (t) {
      prefetchHandle(t.dataset.handle, t.dataset.accType);
    });
  }

  /* Pre-render panels as soon as options are cached — eliminates click-time loading delay */
  function preRenderPanels(handle) {
    var opts = OPT_CACHE[handle];
    if (!Array.isArray(opts)) return;
    document.querySelectorAll('.cart-acc-toggle[data-handle="' + handle + '"]').forEach(function(toggle) {
      var key = toggle.dataset.itemKey;
      var vid = key.split(':')[0];
      var _wrap = toggle.closest('.cart-acc-wrap');
      var panel = _wrap ? _wrap.querySelector('[data-acc-panel]') : document.querySelector('[data-acc-panel="' + key + '"]');
      if (!panel || panel.dataset.loaded) return;
      var wrap = panel.querySelector('.cart-acc-form-wrap');
      if (wrap && wrap.querySelector('.cart-acc-form-select')) return;
      getCart().then(function(c) {
        var it = (c.items || []).find(function(i) { return i.key === key; });
        if (!it) it = (c.items || []).find(function(i) { return String(i.variant_id) === String(vid); });
        renderForm(panel, opts, it ? (it.properties || {}) : {});
        showBtnRow(panel);
      }).catch(function() { renderForm(panel, opts, {}); });
    });
  }

  /* Compute pending accessory cost from current select values in a panel */
  function calcPendingAcc(panel) {
    var total = 0;
    panel.querySelectorAll('.cart-acc-form-select').forEach(function(sel) {
      var txt = sel.options[sel.selectedIndex] ? sel.options[sel.selectedIndex].text : '';
      var m = txt.match(/\(\+\$([0-9,]+\.?\d*)\)/);
      if (!m) m = sel.value.match(/\(\+\$([0-9,]+\.?\d*)\)/);
      if (m) total += Math.round(parseFloat(m[1].replace(/,/g, '')) * 100);
    });
    return total;
  }

  function fmtMoney(cents) {
    return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(cents / 100);
  }

  /* Recompute estimated total from current DOM data-item-* attributes */
  function refreshTotalFromDOM() {
    var total = 0;
    document.querySelectorAll('#CartDrawer-CartItems .cart-item').forEach(function(row) {
      total += (parseInt(row.dataset.itemBase, 10) || 0) + (parseInt(row.dataset.itemAcc, 10) || 0);
    });
    var el = document.querySelector('[data-hvac-cart-total]');
    if (el) el.textContent = fmtMoney(total);
    if (window._hvacApplyProgress) window._hvacApplyProgress(total);
  }

  /* Find the .cart-item <tr> from inside a panel (panel is now inside the qty cell of .cart-item) */
  function getCartItemRow(panel) {
    return panel.closest('.cart-item') || panel._mcCartItem || null;
  }

  function _esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
  function _escA(s) { return String(s).replace(/"/g,'&quot;').replace(/'/g,'&#39;'); }

  /* Rebuild the ACCESSORIES header + prop rows in the acc cell after a save */
  function updateAccDisplay(panel, newProps) {
    var key = panel.dataset.accPanel;
    /* Panel now lives in the qty cell; look up the display cell by item key */
    var accCell = document.querySelector('.cart-item-acc-cell[data-for-key="' + key + '"]');
    if (!accCell) return;
    var accWrap = null; /* acc-cell no longer contains the wrap */

    /* Remove old display rows */
    accCell.querySelectorAll('.cart-item__acc-header, .cart-acc-prop').forEach(function(el) { el.remove(); });

    /* Re-render from saved props */
    var shown = false;
    var xSvg = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 10 10" width="9" height="9" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="1" y1="1" x2="9" y2="9"/><line x1="9" y1="1" x2="1" y2="9"/></svg>';

    Object.keys(newProps).forEach(function(propName) {
      var val = newProps[propName];
      if (!val || val.indexOf('(+$') === -1) return;

      if (!shown) {
        shown = true;
        var hdr = document.createElement('div');
        hdr.className = 'cart-item__acc-header';
        hdr.textContent = 'Accessories';
        accCell.appendChild(hdr);
      }

      var vid = key.split(':')[0];
      var div = document.createElement('div');
      div.className = 'product-option cart-acc-prop';
      div.innerHTML =
        '<span class="cart-acc-text"><dt>' + _esc(propName) + ':</dt><dd> ' + _esc(val) + '</dd></span>'
        + '<button type="button" class="cart-acc-remove"'
        + ' data-item-key="' + _escA(key) + '" data-variant-id="' + _escA(vid) + '" data-item-line="0"'
        + ' data-prop-name="' + _escA(propName) + '"'
        + ' aria-label="Remove ' + _escA(propName) + '">' + xSvg + '</button>';
      accCell.appendChild(div);
    });

    /* Keep the display row's padding and class in sync with whether there's content */
    var accRow = accCell.closest('.cart-item-acc-row');
    if (accRow) accRow.classList.toggle('cart-item-acc-row--has-acc', shown);
  }

  /* Shared in-flight cart.js promise to avoid duplicate requests */
  var _cartPromise = null;
  function getCart() {
    if (_cartPromise) return _cartPromise;
    _cartPromise = fetch('/cart.js', { cache: 'no-store' }).then(function (r) { return r.json(); })
      .finally(function () { setTimeout(function () { _cartPromise = null; }, 3000); });
    return _cartPromise;
  }

  /* Allow the remove IIFE (separate scope) to bust this cache after a successful POST */
  window._hvacClearCartCache = function () { _cartPromise = null; };

  /* ---------- Load accessories for a panel (first open only) ---------- */
  function loadAccessories(toggle) {
    var key    = toggle.dataset.itemKey;
    var handle = toggle.dataset.handle;
    var accType = toggle.dataset.accType;
    if (!key || !handle) return;
    /* Fill cache from dictionary if available and not yet set */
    if (accType && _ACC_OPTS_BY_TYPE[accType] && !Array.isArray(OPT_CACHE[handle])) {
      OPT_CACHE[handle] = _ACC_OPTS_BY_TYPE[accType];
    }

    var _aw = toggle.closest('.cart-acc-wrap');
    var panel = toggle._mcPanel ||
                (_aw ? _aw.querySelector('[data-acc-panel]') : null) ||
                (key ? document.querySelector('[data-acc-panel="' + key + '"]') : null);
    if (!panel || panel.dataset.loaded) return;

    var wrap = panel.querySelector('.cart-acc-form-wrap');
    /* If already pre-rendered, sync selects to current saved state then activate */
    if (wrap && wrap.querySelector('.cart-acc-form-select')) {
      panel.dataset.loaded = '1';
      showBtnRow(panel);
      /* Sync select values to baseProps — may have changed due to X-delete while panel was closed */
      var _bp = {};
      try { _bp = JSON.parse(panel.dataset.baseProps || '{}'); } catch(e) {}
      wrap.querySelectorAll('.cart-acc-form-select').forEach(function(sel) {
        var pn = sel.dataset.propName;
        if (!pn) return;
        sel.value = _bp[pn] || '';
        if (!sel.value) sel.selectedIndex = 0;
      });
      return;
    }
    panel.dataset.loaded = '1';

    /* If options are already cached, render instantly */
    var cachedOpts = OPT_CACHE[handle];
    var vid = key.split(':')[0];
    if (Array.isArray(cachedOpts)) {
      /* Still need current props — fall back to variant ID if key is stale */
      getCart().then(function (c) {
        var it = (c.items || []).find(function (i) { return i.key === key; });
        if (!it) it = (c.items || []).find(function (i) { return String(i.variant_id) === String(vid); });
        renderForm(panel, cachedOpts, it ? (it.properties || {}) : {});
      }).catch(function () { renderForm(panel, cachedOpts, {}); });
      return;
    }

    /* Options not ready yet — show loading, wait for both */
    if (wrap) wrap.innerHTML = '<p class="cart-acc-panel-loading">Loading accessories…</p>';

    var currentProps = {};
    var propsP = getCart()
      .then(function (c) {
        var it = (c.items || []).find(function (i) { return i.key === key; });
        if (!it) it = (c.items || []).find(function (i) { return String(i.variant_id) === String(vid); });
        if (it) currentProps = it.properties || {};
      }).catch(function () {});

    var optsP;
    if (OPT_CACHE[handle] !== undefined) {
      /* In-flight — poll until ready */
      optsP = new Promise(function (res) {
        var t = setInterval(function () {
          if (Array.isArray(OPT_CACHE[handle])) { clearInterval(t); res(OPT_CACHE[handle]); }
        }, 80);
        setTimeout(function () { clearInterval(t); res([]); }, 8000);
      });
    } else {
      OPT_CACHE[handle] = null;
      optsP = fetch('/products/' + handle)
        .then(function (r) { return r.text(); })
        .then(function (html) { var o = parseOpts(html); OPT_CACHE[handle] = o; return o; })
        .catch(function () { OPT_CACHE[handle] = []; return []; });
    }

    Promise.all([optsP, propsP]).then(function (res) {
      renderForm(panel, res[0], currentProps);
    });
  }

  /* ---------- Save selected accessories (fast path — one network call, instant DOM update) ---------- */
  function saveAccessories(btn) {
    if (btn.classList.contains('is-saving')) return;
    btn.classList.add('is-saving');
    btn.textContent = 'Saving…';

    var panel = btn.closest('[data-acc-panel]');
    if (!panel) return;
    var key = panel.dataset.accPanel;
    var vid = key.split(':')[0]; /* variant ID — stable even after key rotation */

    function applySelects(base) {
      var np = Object.assign({}, base);
      panel.querySelectorAll('.cart-acc-form-select').forEach(function(sel) {
        var pn = sel.dataset.propName;
        if (!pn) return;
        var val = sel.value;
        /* Empty / placeholder / "No …" = user wants to remove this accessory */
        if (!val || /^choose|^select/i.test(val) || /^No /i.test(val)) {
          np[pn] = ''; /* explicit empty string tells Shopify to delete the property */
        } else {
          np[pn] = val;
        }
      });
      return np;
    }

    /* Always resolve the current item key before POSTing — key rotates on every property change */
    function postAndUpdate(newProps) {
      if (window._hvacClearCartCache) window._hvacClearCartCache();
      return getCart()
        .then(function(cart) {
          var item = (cart.items || []).find(function(i) { return i.key === key; });
          if (!item) item = (cart.items || []).find(function(i) { return String(i.variant_id) === String(vid); });
          if (!item) throw new Error('[hvac-save] item not found');
          /* Keep panel in sync so subsequent saves use the fresh key */
          key = item.key;
          panel.dataset.accPanel = item.key;
          return fetch('/cart/change.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            body: JSON.stringify({ id: item.key, properties: newProps })
          });
        })
        .then(function(r) {
          if (!r.ok) return r.json().then(function(e) { throw new Error('[hvac-save] ' + (e.description || r.status)); });
          return r.json();
        })
        .then(function(cartResult) {
          btn.textContent = 'Saved!';
          btn.classList.remove('is-saving');

          /* Capture rotated key from POST response and sync all stale DOM references */
          var updatedItems = (cartResult && cartResult.items) || [];
          var updatedItem = updatedItems.find(function(i) { return String(i.variant_id) === String(vid); });
          if (updatedItem && updatedItem.key !== key) {
            var oldSaveKey = key;
            key = updatedItem.key;
            panel.dataset.accPanel = key;
            document.querySelectorAll('.cart-acc-toggle').forEach(function(t) {
              if (t.dataset.itemKey === oldSaveKey) t.dataset.itemKey = key;
            });
            document.querySelectorAll('.cart-item-acc-cell[data-for-key="' + oldSaveKey + '"]').forEach(function(c) {
              c.dataset.forKey = key;
            });
            document.querySelectorAll('.cart-acc-remove[data-item-key="' + oldSaveKey + '"]').forEach(function(b) {
              b.dataset.itemKey = key;
            });
          }

          panel.dataset.baseProps = JSON.stringify(newProps);
          delete panel.dataset.loaded;

          /* Update the ACCESSORIES display immediately with all saved props */
          updateAccDisplay(panel, newProps);

          /* Update line price and cart-item acc data on the sibling cart-item row */
          var row = getCartItemRow(panel);
          if (row) {
            var newAcc = calcPendingAcc(panel);
            row.dataset.itemAcc = String(newAcc);
            var priceEl = row.querySelector('.cart-item__totals .price--end');
            if (priceEl) priceEl.textContent = fmtMoney((parseInt(row.dataset.itemBase, 10) || 0) + newAcc);
          }

          /* Compute true total — prefer DOM-based total (row.dataset.itemAcc already updated above) */
          var _saveTrueTotal = window._hvacCalcDom
            ? window._hvacCalcDom()
            : (window._hvacCalcTrue ? window._hvacCalcTrue((cartResult && cartResult.items) || [], (cartResult && cartResult.total_price) || 0) : ((cartResult && cartResult.total_price) || 0));
          var _saveTotalEl = document.querySelector('[data-hvac-cart-total]');
          if (_saveTotalEl) _saveTotalEl.textContent = fmtMoney(_saveTrueTotal);
          if (window._hvacApplyProgress) window._hvacApplyProgress(_saveTrueTotal);

          /* Sync surcharge line items to match saved accessories, then refresh footer */
          (function () {
            var _svs = window.hvacSurchargeVariants || [];
            /* 1. Remove all existing surcharges for this variant */
            var _toRemove = ((cartResult && cartResult.items) || [])
              .filter(function (i) {
                return i.properties
                  && Object.prototype.hasOwnProperty.call(i.properties, 'Accessory')
                  && String(i.properties._parent_variant || '') === String(vid);
              })
              .map(function (i) { return i.key; });
            /* 2. Build new surcharge entries from saved props */
            var _toAdd = [];
            Object.keys(newProps).forEach(function (pn) {
              var val = newProps[pn];
              if (!val || !val.includes('(+$')) return;
              var _m = val.match(/\(\+\$([0-9,]+\.?\d*)\)/);
              if (!_m) return;
              var _pc = Math.round(parseFloat(_m[1].replace(/,/g, '')) * 100);
              var _sv = _svs.find(function (v) { return v.price === _pc; });
              if (!_sv) return;
              _toAdd.push({ id: _sv.id, label: pn, val: val });
            });
            /* 3. Remove stale → add new → refresh footer */
            Promise.all(_toRemove.map(function (k) {
              return fetch('/cart/change.js', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                body: JSON.stringify({ id: k, quantity: 0 })
              });
            })).then(function () {
              return Promise.all(_toAdd.map(function (entry) {
                return fetch('/cart/add.js', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                  body: JSON.stringify({
                    id: entry.id,
                    quantity: 1,
                    properties: { Accessory: entry.label, Option: entry.val, _parent_variant: String(vid) }
                  })
                });
              }));
            }).then(function () {
              if (window._hvacClearCartCache) window._hvacClearCartCache();
              var _saveCartUrl = (window.routes && window.routes.cart_url) || '/cart';
              return fetch(_saveCartUrl + '?section_id=cart-drawer', { cache: 'no-store' });
            }).then(function (r) { return r.text(); })
              .then(function (html) {
                var doc = new DOMParser().parseFromString(html, 'text/html');
                var tgt = document.querySelector('.cart-drawer__footer');
                var src = doc.querySelector('.cart-drawer__footer');
                if (tgt && src) tgt.replaceWith(src);
                var _fixedEl = document.querySelector('[data-hvac-cart-total]');
                if (_fixedEl) { _fixedEl.textContent = fmtMoney(_saveTrueTotal); _lastTotalApply = Date.now(); }
                if (window._hvacApplyProgress) window._hvacApplyProgress(_saveTrueTotal);
              })
              .catch(function () {});
          }());

          if (window._hvacRefresh) window._hvacRefresh();
          setTimeout(function() { btn.textContent = 'Save Accessories'; }, 2500);
        });
    }

    function onErr() { btn.textContent = 'Save Accessories'; btn.classList.remove('is-saving'); }

    var raw = panel.dataset.baseProps;
    if (raw) {
      try { postAndUpdate(applySelects(JSON.parse(raw))).catch(onErr); }
      catch(e) { postAndUpdate(applySelects({})).catch(onErr); }
    } else {
      postAndUpdate(applySelects({})).catch(onErr);
    }
  }

  /* ---------- Real-time estimated total on select change ---------- */
  document.addEventListener('change', function(e) {
    var sel = e.target;
    if (!sel || !sel.classList.contains('cart-acc-form-select')) return;
    var panel = sel.closest('[data-acc-panel]');
    if (!panel) return;
    var row = getCartItemRow(panel);
    if (!row) return;
    var pendingAcc = calcPendingAcc(panel);
    var base = parseInt(row.dataset.itemBase, 10) || 0;
    var priceEl = row.querySelector('.cart-item__totals .price--end');
    if (priceEl) priceEl.textContent = fmtMoney(base + pendingAcc);
    /* Grand total using pending acc for this row, saved acc for others */
    var total = 0;
    document.querySelectorAll('#CartDrawer-CartItems .cart-item').forEach(function(r) {
      var b = parseInt(r.dataset.itemBase, 10) || 0;
      var a = (r === row) ? pendingAcc : (parseInt(r.dataset.itemAcc, 10) || 0);
      total += b + a;
    });
    var totalEl = document.querySelector('[data-hvac-cart-total]');
    if (totalEl) totalEl.textContent = fmtMoney(total);
    if (window._hvacApplyProgress) window._hvacApplyProgress(total);
  });

  /* ---------- Helper: close a portaled mc-acc-panel and restore it to its original parent ---------- */
  function _mcPanelClose(p) {
    if (p._mcOrig) { p._mcOrig.appendChild(p); p._mcOrig = null; }
    p.setAttribute('hidden', '');
    if (p._mcToggle) { p._mcToggle.setAttribute('aria-expanded', 'false'); p._mcToggle = null; }
    p._mcCartItem = null;
  }

  /* ---------- Close panel when clicking outside ---------- */
  document.addEventListener('click', function (e) {
    /* Allow clicks inside the panel itself (now may be portaled to body) */
    if (e.target.closest && e.target.closest('.cart-acc-wrap')) return;
    if (e.target.closest && e.target.closest('.mc-acc-panel')) return;
    document.querySelectorAll('.cart-acc-panel:not([hidden])').forEach(function (p) {
      if (p.classList.contains('mc-acc-panel')) {
        _mcPanelClose(p);
      } else {
        p.setAttribute('hidden', '');
        var tog = p.closest('.cart-acc-wrap') && p.closest('.cart-acc-wrap').querySelector('.cart-acc-toggle');
        if (tog) tog.setAttribute('aria-expanded', 'false');
      }
    });
  });

  /* ---------- Event delegation ---------- */
  document.addEventListener('click', function (e) {
    var toggle = e.target.closest && e.target.closest('.cart-acc-toggle');
    if (toggle) {
      var key      = toggle.dataset.itemKey;
      var expanded = toggle.getAttribute('aria-expanded') === 'true';
      /* Close all other open panels first */
      document.querySelectorAll('.cart-acc-panel:not([hidden])').forEach(function (p) {
        if (p.dataset.accPanel !== key) {
          if (p.classList.contains('mc-acc-panel')) {
            _mcPanelClose(p);
          } else {
            p.setAttribute('hidden', '');
            var ot = p.closest('.cart-acc-wrap') && p.closest('.cart-acc-wrap').querySelector('.cart-acc-toggle');
            if (ot) ot.setAttribute('aria-expanded', 'false');
          }
        }
      });
      toggle.setAttribute('aria-expanded', String(!expanded));
      var _tw = toggle.closest('.cart-acc-wrap');
      var panel = toggle._mcPanel ||
                  (_tw ? _tw.querySelector('[data-acc-panel]') : (key ? document.querySelector('[data-acc-panel="' + key + '"]') : null));
      if (panel) {
        if (expanded) {
          if (panel.classList.contains('mc-acc-panel')) { _mcPanelClose(panel); toggle.setAttribute('aria-expanded', 'false'); }
          else { panel.setAttribute('hidden', ''); }
        } else {
          panel.removeAttribute('hidden');
          if (panel.classList.contains('mc-acc-panel')) {
            /* Portal to body with document-relative absolute coords so it scrolls with the page */
            var _r  = toggle.getBoundingClientRect();
            var _pw = Math.min(360, window.innerWidth - 16);
            var _lf = Math.max(8, Math.min(_r.left + window.pageXOffset, window.pageXOffset + window.innerWidth - _pw - 8));
            panel._mcOrig     = panel.parentNode;
            panel._mcToggle   = toggle;
            panel._mcCartItem = toggle.closest('.cart-item');
            toggle._mcPanel   = panel;
            panel.style.setProperty('top',   (_r.bottom + window.pageYOffset + 4) + 'px', 'important');
            panel.style.setProperty('left',  _lf + 'px', 'important');
            panel.style.setProperty('width', _pw + 'px', 'important');
            document.body.appendChild(panel);
          }
          loadAccessories(toggle);
        }
      }
      return;
    }

    var saveBtn = e.target.closest && e.target.closest('.cart-acc-save-btn');
    if (saveBtn) { saveAccessories(saveBtn); return; }

    var clearBtn = e.target.closest && e.target.closest('.cart-acc-clear-btn');
    if (clearBtn) {
      var clearPanel = clearBtn.closest('[data-acc-panel]');
      if (!clearPanel) return;
      /* Reset every dropdown to its placeholder */
      clearPanel.querySelectorAll('.cart-acc-form-select').forEach(function(sel) {
        var ph = Array.prototype.findIndex.call(sel.options, function(o) {
          return o.value === '' || /^\s*(choose|select|none|no\b)/i.test(o.text || '');
        });
        sel.selectedIndex = ph >= 0 ? ph : 0;
        sel.value = sel.options[ph >= 0 ? ph : 0] ? sel.options[ph >= 0 ? ph : 0].value : '';
      });
      /* Trigger save immediately so Shopify clears the properties */
      var sibSave = clearPanel.querySelector('.cart-acc-save-btn');
      if (sibSave) saveAccessories(sibSave);
      return;
    }
  });

  /* Pre-fetch options for all items in drawer as soon as script runs */
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', prefetchAll);
  } else {
    setTimeout(prefetchAll, 0);
  }
  /* Also re-prefetch after cart drawer re-renders */
  var _accObserver = new MutationObserver(function () { setTimeout(prefetchAll, 200); });
  var _drawerEl = document.getElementById('CartDrawer-CartItems');
  if (_drawerEl) _accObserver.observe(_drawerEl, { childList: true });
}());
</script>

<script>
/* ===== BFCACHE + CART CONSISTENCY =====
   When the browser restores a page from bfcache (back/forward navigation or
   some "refresh" scenarios), the DOM is frozen at the moment the user left.
   Any accessory deletions or saves that happened before navigating away are
   visible in the DOM, but if the browser restores the OLD snapshot the cart
   shows stale data.  Force a full cart re-render whenever this happens. */
(function () {
  /* pagehide: keep the cart drawer closed so bfcache doesn't restore it open */
  window.addEventListener('pagehide', function (e) {
    if (e.persisted) {
      var cd = document.querySelector('cart-drawer');
      if (cd) cd.removeAttribute('aria-expanded');
      document.querySelectorAll('.cart-acc-panel:not([hidden])').forEach(function (p) {
        p.setAttribute('hidden', '');
        var tog = p.closest('.cart-acc-wrap') && p.closest('.cart-acc-wrap').querySelector('.cart-acc-toggle');
        if (tog) tog.setAttribute('aria-expanded', 'false');
      });
    }
  });

  /* pageshow: if restored from bfcache, refresh the cart drawer immediately
     so any changes made before navigating away are correctly reflected */
  window.addEventListener('pageshow', function (e) {
    if (!e.persisted) return;
    var cd = document.querySelector('cart-drawer');
    if (cd) cd.removeAttribute('aria-expanded');
    /* Re-render cart items from Shopify so deleted/saved accessories show correctly */
    setTimeout(function () {
      var cdi = document.querySelector('cart-drawer-items');
      if (cdi && typeof cdi.onCartUpdate === 'function') cdi.onCartUpdate();
    }, 80);
  });
}());
</script>
