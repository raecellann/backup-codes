            </div>

            <p class="cart-empty-redesign__message">{{ 'sections.cart.empty' | t }}</p>

            <div class="cart-empty-redesign__visual">
              <div class="cart-empty-redesign__image-wrap">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 300 230" fill="none">
                  <!-- Background -->
                  <rect width="300" height="230" fill="#eef3fb"/>
                  <!-- Wall -->
                  <rect x="0" y="0" width="300" height="68" fill="#dce5f0"/>
                  <!-- Mounting brackets -->
                  <rect x="85" y="55" width="22" height="17" rx="4" fill="#b8c8dc"/>
                  <rect x="193" y="55" width="22" height="17" rx="4" fill="#b8c8dc"/>
                  <!-- AC outer body -->
                  <rect x="40" y="63" width="220" height="96" rx="22" fill="#0f2d5c"/>
                  <!-- AC face plate -->
                  <rect x="48" y="70" width="204" height="82" rx="17" fill="#1c4490"/>
                  <!-- Face display panel -->
                  <rect x="68" y="80" width="164" height="64" rx="14" fill="#0b1d45"/>

                  <!-- LEFT EYE -->
                  <circle cx="116" cy="107" r="15" fill="#c8e4ff"/>
                  <circle cx="116" cy="109" r="9" fill="#1d4ed8"/>
                  <circle cx="116" cy="110" r="5" fill="#050e24"/>
                  <circle cx="111" cy="104" r="2.5" fill="white"/>
                  <!-- Droopy upper eyelid -->
                  <path d="M 101 107 Q 116 97 131 107 Z" fill="#0b1d45"/>
                  <!-- Sad eyebrow: outer low → inner high -->
                  <path d="M 102 101 Q 111 94 122 92" stroke="#93c5fd" stroke-width="2.5" fill="none" stroke-linecap="round"/>

                  <!-- RIGHT EYE -->
                  <circle cx="184" cy="107" r="15" fill="#c8e4ff"/>
                  <circle cx="184" cy="109" r="9" fill="#1d4ed8"/>
                  <circle cx="184" cy="110" r="5" fill="#050e24"/>
                  <circle cx="179" cy="104" r="2.5" fill="white"/>
                  <!-- Droopy upper eyelid -->
                  <path d="M 169 107 Q 184 97 199 107 Z" fill="#0b1d45"/>
                  <!-- Sad eyebrow: inner high → outer low -->
                  <path d="M 178 92 Q 189 94 198 101" stroke="#93c5fd" stroke-width="2.5" fill="none" stroke-linecap="round"/>

                  <!-- FROWN MOUTH -->
                  <path d="M 131 130 Q 150 121 169 130" stroke="#93c5fd" stroke-width="2.5" fill="none" stroke-linecap="round"/>

                  <!-- PINK BLUSH CHEEKS -->
                  <circle cx="97" cy="116" r="11" fill="#ffb3c6" opacity="0.38"/>
                  <circle cx="203" cy="116" r="11" fill="#ffb3c6" opacity="0.38"/>

                  <!-- TEARDROPS -->
                  <path d="M 116 122 C 112 130 112 138 116 141 C 120 138 120 130 116 122 Z" fill="#60a5fa"/>
                  <path d="M 184 122 C 180 130 180 138 184 141 C 188 138 188 130 184 122 Z" fill="#60a5fa"/>

                  <!-- BOTTOM VENTS -->
                  <rect x="58" y="158" width="184" height="4" rx="2" fill="#091835"/>
                  <rect x="58" y="165" width="184" height="4" rx="2" fill="#091835"/>

                  <!-- SLOW DROOPY AIRFLOW -->
                  <path d="M 86 173 C 78 188 90 197 82 216" stroke="#93c5fd" stroke-width="2" fill="none" stroke-linecap="round" opacity="0.6"/>
                  <path d="M 116 173 C 110 191 120 200 114 219" stroke="#93c5fd" stroke-width="2" fill="none" stroke-linecap="round" opacity="0.6"/>
                  <path d="M 150 173 C 148 193 152 202 150 221" stroke="#93c5fd" stroke-width="2" fill="none" stroke-linecap="round" opacity="0.6"/>
                  <path d="M 184 173 C 190 191 180 200 186 219" stroke="#93c5fd" stroke-width="2" fill="none" stroke-linecap="round" opacity="0.6"/>
                  <path d="M 214 173 C 222 188 210 197 218 216" stroke="#93c5fd" stroke-width="2" fill="none" stroke-linecap="round" opacity="0.6"/>
                </svg>
              </div>
              <p class="cart-empty-redesign__brand">HVACMORE</p>
              <a href="{{ routes.all_products_collection_url }}" class="cart-empty-redesign__shop-link">Discover our products</a>
            </div>

            <div class="cart-empty-redesign__cta">
              <a href="{{ routes.all_products_collection_url }}" class="button cart-empty-redesign__btn">
                {{ 'general.continue_shopping' | t }}
              </a>
              {%- if shop.customer_accounts_enabled and customer == null -%}
                <div class="cart-empty-redesign__login">
                  <p class="cart__login-title h3">{{ 'sections.cart.login.title' | t }}</p>
                  <p class="cart__login-paragraph">
                    {{ 'sections.cart.login.paragraph_html' | t: link: routes.account_login_url }}
                  </p>
                </div>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endif -%}
      <div class="drawer__header">
        <h2 class="drawer__heading">{{ 'sections.cart.title' | t }}</h2>
        <button
          class="drawer__close"
          type="button"
          onclick="this.closest('cart-drawer').close()"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          <span class="svg-wrapper">
            {{- 'icon-close.svg' | inline_asset_content -}}
          </span>
        </button>
      </div>

      {%- assign _acc_extra_cents = 0 -%}
      {%- assign _drawer_surcharge_total = 0 -%}
      {%- for item in cart.items -%}
        {%- if item.properties['Accessory'] -%}
          {%- assign _drawer_surcharge_total = _drawer_surcharge_total | plus: item.final_line_price -%}
        {%- else -%}
          {%- for property in item.properties -%}
            {%- assign _pfc = property.first | slice: 0 -%}
            {%- if property.last != blank and _pfc != '_' and property.last contains '(+$' -%}
              {%- assign _acc_price_raw = property.last | split: '(+$' | last | split: ')' | first | remove: ',' -%}
              {%- assign _acc_price_cents = _acc_price_raw | times: 100 | round | times: item.quantity -%}
              {%- assign _acc_extra_cents = _acc_extra_cents | plus: _acc_price_cents -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      {%- endfor -%}
      {%- assign _cart_true_total = cart.total_price | minus: _drawer_surcharge_total | plus: _acc_extra_cents -%}

      {%- comment -%}REWARD PROGRESS BAR — milestone: $500 free shipping{%- endcomment -%}
      {%- liquid
        assign fs = 50000
        assign ct = _cart_true_total
        if ct >= fs
          assign seg1 = 100
          assign milestone = 1
          assign remaining = 0
        else
          assign seg1 = ct | times: 100 | divided_by: fs
          assign milestone = 0
          assign remaining = fs | minus: ct
        endif
        assign rem_d = remaining | divided_by: 100
        assign rem_c = remaining | modulo: 100
        assign rem_c_str = rem_c | prepend: '00' | slice: -2, 2
      -%}
      {%- assign checkmark_svg = '<svg viewBox="0 0 16 16" fill="currentColor"><path d="M13.854 3.646a.5.5 0 0 1 0 .708l-7 7a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L6.5 10.293l6.646-6.647a.5.5 0 0 1 .708 0z"/></svg>' -%}
      {%- assign truck_svg = '<svg viewBox="0 0 16 16" fill="currentColor"><path d="M0 3.5A1.5 1.5 0 0 1 1.5 2h9A1.5 1.5 0 0 1 12 3.5V5h1.02a1.5 1.5 0 0 1 1.17.563l1.481 1.85a1.5 1.5 0 0 1 .329.938V10.5a1.5 1.5 0 0 1-1.5 1.5H14a2 2 0 1 1-4 0H5a2 2 0 1 1-3.998-.085A1.5 1.5 0 0 1 0 10.5v-7zm6 8a1 1 0 1 0-2 0 1 1 0 0 0 2 0zm6.5 0a1 1 0 1 0-2 0 1 1 0 0 0 2 0z"/></svg>' -%}
      {%- assign filter_svg = '<svg viewBox="0 0 16 16" fill="currentColor"><path d="M1.5 1.5A.5.5 0 0 1 2 1h12a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.128.334L10 8.692V13.5a.5.5 0 0 1-.342.474l-3 1A.5.5 0 0 1 6 14.5V8.692L1.628 3.834A.5.5 0 0 1 1.5 3.5v-2z"/></svg>' -%}
      {%- assign gift_svg = '<svg viewBox="0 0 16 16" fill="currentColor"><path d="M3 2.5a2.5 2.5 0 0 1 5 0 2.5 2.5 0 0 1 5 0v.006c0 .07 0 .27-.038.494H15a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1v7.5a1.5 1.5 0 0 1-1.5 1.5h-11A1.5 1.5 0 0 1 1 14.5V7a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h2.038A2.968 2.968 0 0 1 3 2.506V2.5zm1.068.5H7v-.5a1.5 1.5 0 1 0-3 0c0 .085.002.274.045.43a.522.522 0 0 1 .023.07zM9 3h2.932a.56.56 0 0 1 .023-.07c.043-.156.045-.345.045-.43a1.5 1.5 0 0 0-3 0V3zM1 4v2h6V4H1zm8 0v2h6V4H9zm5 3H9v8h4.5a.5.5 0 0 0 .5-.5V7zm-7 8V7H2v7.5a.5.5 0 0 0 .5.5H7z"/></svg>' -%}

      <div class="cart-progress-wrap" data-fs="{{ fs }}">
        <div class="cart-progress__steps">
          <div class="cart-progress__step{% if milestone >= 1 %} is-done{% endif %}">
            <div class="cart-progress__icon">{{ truck_svg }}</div>
            <span class="cart-progress__step-label">Free Shipping<small class="cart-progress__threshold">$500+</small></span>
          </div>
        </div>
        <div class="cart-progress__bar-wrap">
          <div class="cart-progress__seg{% if milestone >= 1 %} is-complete{% endif %}">
            <div class="cart-progress__seg-fill" style="width:{{ seg1 }}%"></div>
          </div>
        </div>
        {%- if milestone >= 1 -%}
          <p class="cart-progress__all-done">You've unlocked free shipping — thank you!</p>
        {%- else -%}
          <p class="cart-progress__msg">
            You are <strong>${{ rem_d }}.{{ rem_c_str }}</strong> away from <strong>free shipping</strong>!
          </p>
        {%- endif -%}
      </div>

      <cart-drawer-items
        {% if cart == empty %}
          class=" is-empty"
        {% endif %}
      >
        <form
          action="{{ routes.cart_url }}"
          id="CartDrawer-Form"
          class="cart__contents cart-drawer__form"
          method="post"
        >
          <div id="CartDrawer-CartItems" class="drawer__contents js-contents">
            {%- if cart != empty -%}
              <div class="drawer__cart-items-wrapper">
                <table class="cart-items" role="table">
                  <thead role="rowgroup">
                    <tr role="row">
                      <th id="CartDrawer-ColumnProductImage" role="columnheader">
                        <span class="visually-hidden">{{ 'sections.cart.headings.image' | t }}</span>
                      </th>
                      <th
                        id="CartDrawer-ColumnProduct"
                        class="caption-with-letter-spacing"
                        scope="col"
                        role="columnheader"
                      >
                        {{ 'sections.cart.headings.product' | t }}
                      </th>
                      <th
                        id="CartDrawer-ColumnTotal"
                        class="right caption-with-letter-spacing"
                        scope="col"
                        role="columnheader"
                      >
                        {{ 'sections.cart.headings.total' | t }}
                      </th>
                      <th id="CartDrawer-ColumnQuantity" role="columnheader">
                        <span class="visually-hidden">{{ 'sections.cart.headings.quantity' | t }}</span>
                      </th>
                    </tr>
                  </thead>

                  <tbody role="rowgroup">
                    {%- for item in cart.items -%}
                      {%- assign _is_surcharge_item = false -%}
                      {%- for _sp in item.properties -%}
                        {%- if _sp.first == 'Accessory' -%}{%- assign _is_surcharge_item = true -%}{%- break -%}{%- endif -%}
                      {%- endfor -%}
                      {%- unless _is_surcharge_item -%}
                      {%- assign _item_acc_cents = 0 -%}
                      {%- for property in item.properties -%}
                        {%- assign _pfc = property.first | slice: 0 -%}
                        {%- if property.last != blank and _pfc != '_' and property.last contains '(+$' -%}
                          {%- assign _acc_price_raw = property.last | split: '(+$' | last | split: ')' | first | remove: ',' -%}
                          {%- assign _acc_price_cents = _acc_price_raw | times: 100 | round | times: item.quantity -%}
                          {%- assign _item_acc_cents = _item_acc_cents | plus: _acc_price_cents -%}
                        {%- endif -%}
                      {%- endfor -%}
                      <tr  data-hulkapps-lineitem data-item-base="{{ item.final_line_price }}" data-item-acc="{{ _item_acc_cents }}" id="CartDrawer-Item-{{ item.index | plus: 1 }}" class="cart-item" role="row">
                        <td class="cart-item__media" role="cell" headers="CartDrawer-ColumnProductImage">
                          <div class="cart-item__media-wrap">
                            <label class="cart-item__select">
                              <input type="checkbox" class="cart-item__select-input" checked>
                            </label>
                            {% if item.image %}
                              <div class="cart-item__image-group">
                                {% comment %} Leave empty space due to a:empty CSS display: none rule {% endcomment %}
                                <a href="{{ item.url }}" class="cart-item__link" tabindex="-1" aria-hidden="true"> </a>
                                <img
                                  class="cart-item__image"
                                  src="{{ item.image | image_url: width: 300 }}"
                                  alt="{{ item.image.alt | escape }}"
                                  loading="lazy"
                                  width="150"
                                  height="{{ 150 | divided_by: item.image.aspect_ratio | ceil }}"
                                >
                              </div>
                            {% endif %}
                          </div>
                        </td>

                        <td class="cart-item__details" role="cell" headers="CartDrawer-ColumnProduct">
                          {%- if settings.show_vendor -%}
                            <p class="caption-with-letter-spacing light">{{ item.product.vendor }}</p>
                          {%- endif -%}

                          <a href="{{ item.url }}" class="cart-item__name h4 break">
                            {{- item.product.title | escape -}}
                          </a>

                          {%- if item.original_price != item.final_price -%}
                            <div class="cart-item__discounted-prices">
                              <span class="visually-hidden">
                                {{ 'products.product.price.regular_price' | t }}
                              </span>
                              <s  data-hulkapps-ci-price data-key='{{item.key}}' class="cart-item__old-price product-option">
                                {{- item.original_price | money -}}
                              </s>
                              <span class="visually-hidden">
                                {{ 'products.product.price.sale_price' | t }}
                              </span>
                              <strong  data-hulkapps-ci-price data-key='{{item.key}}' class="cart-item__final-price product-option">
                                {{ item.final_price | money }}
                              </strong>
                            </div>
                          {%- else -%}
                            <div  data-hulkapps-ci-price data-key='{{item.key}}' class="product-option">
                              {{ item.original_price | money }}
                            </div>
                          {%- endif -%}

                          {%- if item.product.has_only_default_variant == false
                            or item.properties.size != 0
                            or item.selling_plan_allocation != null
                          -%}
                            <dl>
                              {%- if item.product.has_only_default_variant == false -%}
                                {%- for option in item.options_with_values -%}
                                  {%- assign val_start = option.value | slice: 0, 3 -%}
                                  {%- assign val_lower4 = option.value | downcase | slice: 0, 4 -%}
                                  {%- unless val_start == 'No ' or val_lower4 == 'none' or option.value == blank -%}
                                    {%- assign _opt_name_lc = option.name | downcase -%}
                                    {%- if _opt_name_lc contains 'tonnage' -%}
                                      {%- assign _opt_label = 'Selected tonnage' -%}
                                    {%- elsif _opt_name_lc contains 'seer' -%}
                                      {%- assign _opt_label = 'Selected SEER2 efficiency' -%}
                                    {%- else -%}
                                      {%- assign _opt_label = option.name | remove: 'Choose ' | remove: 'Optional ' -%}
                                    {%- endif -%}
                                    <div class="product-option">
                                      <dt>{{ _opt_label }}:</dt>
                                      <dd>{{ option.value }}</dd>
                                    </div>
                                  {%- endunless -%}
                                {%- endfor -%}
                              {%- endif -%}

<span data-hulkapps-line-properties>
                              {%- for property in item.properties -%}
                                {%- assign property_first_char = property.first | slice: 0 -%}
                                {%- assign prop_val_start = property.last | slice: 0, 3 -%}
                                {%- assign prop_val_lower4 = property.last | downcase | slice: 0, 4 -%}
                                {%- assign prop_val_lower6 = property.last | downcase | slice: 0, 6 -%}
                                {%- if property.last != blank and property_first_char != '_' and prop_val_start != 'No ' and prop_val_lower4 != 'none' and prop_val_lower6 != 'choose' -%}
                                  {%- unless property.last contains '(+$' -%}
                                    {%- assign _prop_name_lc = property.first | downcase -%}
                                    {%- if _prop_name_lc contains 'tonnage' -%}
                                      {%- assign _prop_label = 'Selected tonnage' -%}
                                    {%- elsif _prop_name_lc contains 'seer' -%}
                                      {%- assign _prop_label = 'Selected SEER2 efficiency' -%}
                                    {%- else -%}
                                      {%- assign _prop_label = property.first -%}
                                    {%- endif -%}
                                    <div class="product-option">
                                      <dt>{{ _prop_label }}:</dt>
                                      <dd>
                                        {%- if property.last contains '/uploads/' -%}
                                          <a
                                            href="{{ property.last }}"
                                            class="link"
                                            target="_blank"
                                            aria-describedby="a11y-new-window-message"
                                          >
                                            {{ property.last | split: '/' | last }}
                                          </a>
                                        {%- else -%}
                                          {{ property.last }}
                                        {%- endif -%}
                                      </dd>
                                    </div>
                                  {%- endunless -%}
                                {%- endif -%}
                              {%- endfor -%}
</span>
<button type='button' style='display: none;' class='edit_cart_option btn btn--primary button' data-product_id='{{item.product_id}}' data-key='{{item.key}}' data-variant_id='{{item.variant_id}}' data-quantity='{{item.quantity}}'>Edit Options</button>
                            </dl>

                            <p class="product-option">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                          {%- endif -%}

                          <ul
                            class="discounts list-unstyled"
                            role="list"
                            aria-label="{{ 'customer.order.discount' | t }}"
                          >
                            {%- for discount in item.line_level_discount_allocations -%}
                              <li class="discounts__discount">
                                {{- 'icon-discount.svg' | inline_asset_content -}}
                                {{ discount.discount_application.title }}
                              </li>
                            {%- endfor -%}
                          </ul>

                        </td>

                        <td class="cart-item__totals right" role="cell" headers="CartDrawer-ColumnTotal">
                          {%- render 'loading-spinner' -%}
                          <div class="cart-item__price-wrapper">
                            {%- assign _display_original = item.original_line_price | plus: _item_acc_cents -%}
                            {%- assign _display_final = item.final_line_price | plus: _item_acc_cents -%}
                            {%- if item.original_line_price != item.final_line_price -%}
                              <div class="cart-item__discounted-prices">
                                <span class="visually-hidden">
                                  {{ 'products.product.price.regular_price' | t }}
                                </span>
                                <s  data-hvac-line-price data-key='{{item.key}}' class="cart-item__old-price price price--end">
                                  {{ _display_original | money }}
                                </s>
                                <span class="visually-hidden">
                                  {{ 'products.product.price.sale_price' | t }}
                                </span>
                                <span  data-hvac-line-price data-key='{{item.key}}' class="price price--end">
                                  {{ _display_final | money }}
                                </span>
                              </div>
                            {%- else -%}
                              <span  data-hvac-line-price data-key='{{item.key}}' class="price price--end">
                                {{ _display_original | money }}
                              </span>
                            {%- endif -%}

                            {%- if item.variant.available and item.unit_price_measurement -%}
                              <div class="unit-price caption">
                                <span class="visually-hidden">{{ 'products.product.price.unit_price' | t }}</span>
                                {{ item.unit_price | money }}
                                <span aria-hidden="true">/</span>
                                <span class="visually-hidden"
                                  >&nbsp;{{ 'accessibility.unit_price_separator' | t }}&nbsp;</span
                                >
                                {%- if item.unit_price_measurement.reference_value != 1 -%}
                                  {{- item.unit_price_measurement.reference_value -}}
                                {%- endif -%}
                                {{ item.unit_price_measurement.reference_unit }}
                              </div>
                            {%- endif -%}
                          </div>
                        </td>
                        {%- liquid
                          assign has_qty_rules = false
                          if item.variant.quantity_rule.increment > 1 or item.variant.quantity_rule.min > 1 or item.variant.quantity_rule.max != null
                            assign has_qty_rules = true
                          endif

                          assign has_vol_pricing = false
                          if item.variant.quantity_price_breaks.size > 0
                            assign has_vol_pricing = true
                          endif
                        -%}
                        <td
                          class="cart-item__quantity {% if has_qty_rules or has_vol_pricing %} cart-item__quantity--info{% endif %}"
                          role="cell"
                          headers="CartDrawer-ColumnQuantity"
                        >
                          <quantity-popover>
                            <div class="cart-item__quantity-wrapper quantity-popover-wrapper">
                              <div class="quantity-popover-container{% if has_qty_rules or has_vol_pricing %} quantity-popover-container--hover{% endif %}">
                                <quantity-input class="quantity cart-quantity">
                                  <button class="quantity__button" name="minus" type="button">
                                    <span class="visually-hidden">
                                      {{-
                                        'products.product.quantity.decrease'
                                        | t: product: item.product.title
                                        | escape
                                      -}}
                                    </span>
                                    <span class="svg-wrapper">
                                      {{- 'icon-minus.svg' | inline_asset_content -}}
                                    </span>
                                  </button>
                                  <input
                                    class="quantity__input"
                                    type="number"
                                    data-quantity-variant-id="{{ item.variant.id }}"
                                    name="updates[]"
                                    value="{{ item.quantity }}"
                                    {% # theme-check-disable %}
                                    data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                                    min="0"
                                    data-min="{{ item.variant.quantity_rule.min }}"
                                    {% if item.variant.quantity_rule.max != null %}
                                      max="{{ item.variant.quantity_rule.max }}"
                                    {% endif %}
                                    step="{{ item.variant.quantity_rule.increment | default: 1 }}"
                                    {% # theme-check-enable %}
                                    aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                                    id="Drawer-quantity-{{ item.index | plus: 1 }}"
                                    data-index="{{ item.index | plus: 1 }}"
                                  >
                                  <button class="quantity__button" name="plus" type="button">
                                    <span class="visually-hidden">
                                      {{-
                                        'products.product.quantity.increase'
                                        | t: product: item.product.title
                                        | escape
                                      -}}
                                    </span>
                                    <span class="svg-wrapper">
                                      {{- 'icon-plus.svg' | inline_asset_content -}}
                                    </span>
                                  </button>
                                </quantity-input>
                              </div>
                              <cart-remove-button
                                id="CartDrawer-Remove-{{ item.index | plus: 1 }}"
                                data-index="{{ item.index | plus: 1 }}"
                              >
                                <button
                                  type="button"
                                  class="button button--tertiary cart-remove-button"
                                  aria-label="{{ 'sections.cart.remove_title' | t: title: item.title | escape }}"
                                  data-variant-id="{{ item.variant.id }}"
                                >
                                  <span class="svg-wrapper">
                                    {{- 'icon-remove.svg' | inline_asset_content -}}
                                  </span>
                                </button>
                              </cart-remove-button>
                            </div>
                            {%- if has_qty_rules or has_vol_pricing -%}
                              <button
                                type="button"
                                class="quantity-popover__info-button quantity-popover__info-button--icon-with-label button button--tertiary"
                                aria-expanded="false"
                              >
                                <span class="svg-wrapper">
                                  {{- 'icon-info.svg' | inline_asset_content -}}
                                </span>
                                <span>
                                  {%- if has_vol_pricing -%}
                                    {{ 'products.product.volume_pricing.note' | t }}
                                  {%- elsif has_qty_rules -%}
                                    {{ 'products.product.quantity.note' | t }}
                                  {%- endif -%}
                                </span>
                              </button>
                            {%- endif -%}
                            {%- if has_vol_pricing or has_qty_rules -%}
                              <div
                                class="cart-items__info global-settings-popup quantity-popover__info"
                                tabindex="-1"
                                hidden
                              >
                                {%- if has_qty_rules == false -%}
                                  <span class="volume-pricing-label caption">
                                    {{- 'products.product.volume_pricing.title' | t -}}
                                  </span>
                                {%- endif -%}
                                <div class="quantity__rules caption">
                                  {%- if item.variant.quantity_rule.increment > 1 -%}
                                    <span class="divider">
                                      {{-
                                        'products.product.quantity.multiples_of'
                                        | t: quantity: item.variant.quantity_rule.increment
                                      -}}
                                    </span>
                                  {%- endif -%}
                                  {%- if item.variant.quantity_rule.min > 1 -%}
                                    <span class="divider">
                                      {{-
                                        'products.product.quantity.min_of'
                                        | t: quantity: item.variant.quantity_rule.min
                                      -}}
                                    </span>
                                  {%- endif -%}
                                  {%- if item.variant.quantity_rule.max != null -%}
                                    <span class="divider">
                                      {{-
                                        'products.product.quantity.max_of'
                                        | t: quantity: item.variant.quantity_rule.max
                                      -}}
                                    </span>
                                  {%- endif -%}
                                </div>
                                <button
                                  class="button-close button button--tertiary"
                                  type="button"
                                  aria-label="{{ 'accessibility.close' | t }}"
                                >
                                  <span class="svg-wrapper">
                                    {{- 'icon-close.svg' | inline_asset_content -}}
                                  </span>
                                </button>
                                {%- if item.variant.quantity_price_breaks.size > 0 -%}
                                  <volume-pricing class="parent-display">
                                    <ul class="list-unstyled">
                                      <li>
                                        <span>{{ item.variant.quantity_rule.min }}+</span>
                                        <span>{{ item.variant.price | money_with_currency }}/ea</span>
                                      </li>
                                      {%- for price_break in item.variant.quantity_price_breaks -%}
                                        <li>
                                          <span>
                                            {{- price_break.minimum_quantity -}}
                                            <span aria-hidden="true">+</span></span
                                          >
                                          <span>{{ price_break.price | money_with_currency }}/ea</span>
                                        </li>
                                      {%- endfor -%}
                                    </ul>
                                  </volume-pricing>
                                {%- endif -%}
                              </div>
                            {%- endif -%}
                            <div
                              id="CartDrawer-LineItemError-{{ item.index | plus: 1 }}"
                              class="cart-item__error"
                              role="alert"
                            >
                              <small class="cart-item__error-text"></small>
                              <span class="svg-wrapper">
                                {{- 'icon-error.svg' | inline_asset_content -}}
                              </span>
                            </div>
                          </quantity-popover>
                          {%- if item.variant.quantity_price_breaks.size > 0 -%}
                            {%- assign _break = item.variant.quantity_price_breaks.first -%}
                            {%- assign _savings_raw = item.original_price | minus: _break.price -%}
                            {%- assign _savings_pct = _savings_raw | times: 100 | divided_by: item.original_price -%}
                            {%- if _savings_pct > 0 -%}
                              <div class="cart-item__vol-badge">
                                Buy {{ _break.minimum_quantity }}, save {{ _savings_pct }}%
                              </div>
                            {%- endif -%}
                          {%- endif -%}
                          {%- assign _ci_acc_type = '' -%}
                          {%- if item.product.template_suffix == 'condenser-accessories' -%}{%- assign _ci_acc_type = 'condenser' -%}
                          {%- elsif item.product.template_suffix == 'furnace-accessories' -%}{%- assign _ci_acc_type = 'furnace' -%}
                          {%- elsif item.product.template_suffix == 'coil-accessories' -%}{%- assign _ci_acc_type = 'evaporator-coils' -%}
                          {%- else -%}
                            {%- assign _ci_any_meta = false -%}
                            {%- for _ci_col in item.product.collections -%}
                              {%- assign _ci_meta = _ci_col.metafields.custom.accessories_type | downcase | strip -%}
                              {%- if _ci_meta != blank -%}{%- assign _ci_any_meta = true -%}{%- endif -%}
                            {%- endfor -%}
                            {%- for _ci_col in item.product.collections -%}
                              {%- assign _ci_meta = _ci_col.metafields.custom.accessories_type | downcase | strip -%}
                              {%- if _ci_meta == 'condenser' -%}{%- assign _ci_acc_type = 'condenser' -%}
                              {%- elsif _ci_meta == 'furnace' -%}{%- assign _ci_acc_type = 'furnace' -%}
                              {%- elsif _ci_meta == 'heat-pump' -%}{%- assign _ci_acc_type = 'heat-pump' -%}
                              {%- elsif _ci_meta == 'ac-furnace' -%}{%- assign _ci_acc_type = 'ac-furnace' -%}
                              {%- elsif _ci_meta == 'ac-furnace-kit' -%}{%- assign _ci_acc_type = 'ac-furnace-kit' -%}
                              {%- elsif _ci_meta == 'propane' -%}{%- assign _ci_acc_type = 'propane' -%}
                              {%- elsif _ci_meta == blank and _ci_any_meta == false -%}
                                {%- if _ci_col.handle == 'ac-condensers' -%}{%- assign _ci_acc_type = 'condenser' -%}
                                {%- elsif _ci_col.handle == 'gas-furnaces' or _ci_col.handle == 'natural-gas-furnaces' -%}{%- assign _ci_acc_type = 'furnace' -%}
                                {%- elsif _ci_col.handle == 'heat-pumps' -%}{%- assign _ci_acc_type = 'heat-pump' -%}
                                {%- elsif _ci_col.handle == 'ac-furnace' or _ci_col.handle == 'ac-furnace-system' -%}{%- assign _ci_acc_type = 'ac-furnace' -%}
                              {%- endif -%}
                            {%- endif -%}
                            {%- endfor -%}
                          {%- endif -%}
                          {%- unless item.product.template_suffix == 'product-without-accessori' or item.product.template_suffix == 'extended-warranty' -%}
                          <div class="cart-acc-wrap">
                            <button
                              type="button"
                              class="cart-acc-toggle"
                              data-item-key="{{ item.key }}"
                              data-handle="{{ item.product.handle }}"
                              data-acc-type="{{ _ci_acc_type }}"
                              aria-expanded="false"
                            >
                              <span>Choose Your Accessories</span>
                              <svg class="cart-acc-toggle__chevron" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" width="14" height="14">
                                <path d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/>
                              </svg>
                            </button>
                            <div class="cart-acc-panel" data-acc-panel="{{ item.key }}" data-base-props="{{ item.properties | json | escape }}" hidden>
                              <div class="cart-acc-form-wrap"></div>
                              <div class="cart-acc-btn-row" hidden>
                                <button type="button" class="cart-acc-clear-btn">Clear All</button>
                                <button type="button" class="cart-acc-save-btn">Save Accessories</button>
                              </div>
                            </div>
                          </div>
                          {%- endunless -%}
                        </td>
                      </tr>
                      {%- assign _acc_row_shown = false -%}
                      {%- for property in item.properties -%}
                        {%- assign _pfc = property.first | slice: 0 -%}
                        {%- if property.last != blank and _pfc != '_' and property.last contains '(+$' -%}
                          {%- assign _acc_row_shown = true -%}
                        {%- endif -%}
                      {%- endfor -%}
                      <tr class="cart-item-acc-row{% if _acc_row_shown %} cart-item-acc-row--has-acc{% endif %}" id="CartDrawer-AccRow-{{ item.index | plus: 1 }}">
                        <td colspan="4" class="cart-item-acc-cell" data-for-key="{{ item.key }}">
                          {%- assign _acc_row_hdr_shown = false -%}
                          {%- for property in item.properties -%}
                            {%- assign _pfc = property.first | slice: 0 -%}
                            {%- if property.last != blank and _pfc != '_' and property.last contains '(+$' -%}
                              {%- unless _acc_row_hdr_shown -%}
                                {%- assign _acc_row_hdr_shown = true -%}
                                <div class="cart-item__acc-header">Accessories</div>
                              {%- endunless -%}
                              <div class="product-option cart-acc-prop">
                                <span class="cart-acc-text">
                                  <dt>{{ property.first }}:</dt>
                                  <dd>{{ property.last }}</dd>
                                </span>
                                <button
                                  type="button"
                                  class="cart-acc-remove"
                                  data-item-key="{{ item.key }}"
                                  data-variant-id="{{ item.variant_id }}"
                                  data-item-line="{{ item.line }}"
                                  data-prop-name="{{ property.first | escape }}"
                                  aria-label="Remove {{ property.first | escape }}"
                                >
                                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 10 10" width="9" height="9" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                                    <line x1="1" y1="1" x2="9" y2="9"/><line x1="9" y1="1" x2="1" y2="9"/>
                                  </svg>
                                </button>
                              </div>
                            {%- endif -%}
                          {%- endfor -%}
                        </td>
                      </tr>
                      {%- endunless -%}
                    {%- endfor -%}
                  </tbody>
                </table>
              </div>
            {%- endif -%}
            <p id="CartDrawer-LiveRegionText" class="visually-hidden" role="status"></p>
            <p id="CartDrawer-LineItemStatus" class="visually-hidden" aria-hidden="true" role="status">
              {{ 'accessibility.loading' | t }}
            </p>
          </div>
          <div id="CartDrawer-CartErrors" role="alert"></div>
        </form>
        <div id="CartDrawer-Upsell" class="cart-upsell" aria-live="polite"></div>
      </cart-drawer-items>
      <div class="drawer__footer">
        {%- if settings.show_cart_note -%}
          <details id="Details-CartDrawer">
            <summary>
              <span class="summary__title">
                {{ 'sections.cart.note' | t }}
                {{- 'icon-caret.svg' | inline_asset_content -}}
              </span>
            </summary>
            <cart-note class="cart__note field">
              <label class="visually-hidden" for="CartDrawer-Note">{{ 'sections.cart.note' | t }}</label>
              <textarea
                id="CartDrawer-Note"
                class="text-area text-area--resize-vertical field__input"
                name="note"
                placeholder="{{ 'sections.cart.note' | t }}"
              >{{ cart.note }}</textarea>
            </cart-note>
          </details>
        {%- endif -%}

        <!-- Start blocks -->
        <!-- Subtotals -->

        <div class="cart-drawer__footer" {{ block.shopify_attributes }}>
          <div>
            {%- if cart.cart_level_discount_applications.size > 0 -%}
              <ul class="discounts list-unstyled" role="list" aria-label="{{ 'customer.order.discount' | t }}">
                {%- for discount in cart.cart_level_discount_applications -%}
                  <li class="discounts__discount discounts__discount--end">
                    {{- 'icon-discount.svg' | inline_asset_content -}}
                    {{ discount.title | escape }}
                    (-{{ discount.total_allocated_amount | money }})
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>

          <div class="totals" role="status">
            <h2 class="totals__total">{{ 'sections.cart.estimated_total' | t }}</h2>
            <p data-hvac-cart-total data-acc-extra="{{ _acc_extra_cents }}" class="totals__total-value">{{ _cart_true_total | money_with_currency }}</p>
          </div>

          <small class="tax-note caption-large rte">
            {%- if cart.duties_included and cart.taxes_included -%}
              {%- if shop.shipping_policy.body == blank -%}
                {{ 'sections.cart.duties_and_taxes_included_shipping_at_checkout_without_policy' | t }}
              {%- else -%}
                {{
                  'sections.cart.duties_and_taxes_included_shipping_at_checkout_with_policy_html'
                  | t: link: shop.shipping_policy.url
                }}
              {%- endif -%}
            {%- elsif cart.duties_included == false and cart.taxes_included -%}
              {%- if shop.shipping_policy.body == blank -%}
                {{ 'sections.cart.taxes_included_shipping_at_checkout_without_policy' | t }}
              {%- else -%}
                {{
                  'sections.cart.taxes_included_shipping_at_checkout_with_policy_html'
                  | t: link: shop.shipping_policy.url
                }}
              {%- endif -%}
            {%- elsif cart.duties_included and cart.taxes_included == false -%}
              {%- if shop.shipping_policy.body == blank -%}
                {{ 'sections.cart.duties_included_taxes_at_checkout_shipping_at_checkout_without_policy' | t }}
              {%- else -%}
                {{
                  'sections.cart.duties_included_taxes_at_checkout_shipping_at_checkout_with_policy_html'
                  | t: link: shop.shipping_policy.url
                }}
              {%- endif -%}
            {%- elsif cart.duties_included == false and cart.taxes_included == false -%}
              {%- if shop.shipping_policy.body == blank -%}
                {{ 'sections.cart.taxes_at_checkout_shipping_at_checkout_without_policy' | t }}
              {%- else -%}
                {{
                  'sections.cart.taxes_at_checkout_shipping_at_checkout_with_policy_html'
                  | t: link: shop.shipping_policy.url
                }}
              {%- endif -%}
            {%- endif -%}
          </small>
        </div>

        <!-- CTAs -->

        <div class="cart__ctas" {{ block.shopify_attributes }}>
          <button
            type="submit"
            id="CartDrawer-Checkout"
            class="cart__checkout-button button"
            name="checkout"
            form="CartDrawer-Form"
            {% if cart == empty %}
              disabled
            {% endif %}
          >
            {{ 'sections.cart.checkout' | t }}
          </button>
        </div>
      </div>
    </div>
  </div>
</cart-drawer>

<script>
(function () {
  var FS = 50000;

  function resizeImg(url, size) {
    if (!url) return '';
    if (url.startsWith('//')) url = 'https:' + url;
    var sep = url.indexOf('?') !== -1 ? '&' : '?';
    return url + sep + 'width=' + size;
  }

  function fmt(cents) {
    return '$' + Math.floor(cents / 100) + '.' + String(cents % 100).padStart(2, '0');
  }

  function calcProgress(total) {
    var seg1 = 0, milestone = 0, remaining = 0;
    if (total >= FS) {
      seg1 = 100; milestone = 1;
    } else {
      seg1 = Math.min(100, Math.round(total / FS * 100));
      milestone = 0; remaining = FS - total;
    }
    return { seg1: seg1, milestone: milestone, remaining: remaining };
  }


  function applyProgress(total) {
    var wrap = document.querySelector('.cart-progress-wrap');
    if (!wrap) return;
    var p = calcProgress(total);

    wrap.querySelectorAll('.cart-progress__step').forEach(function (s, i) {
      s.classList.toggle('is-done', p.milestone > i);
    });

    wrap.querySelectorAll('.cart-progress__seg').forEach(function (seg, i) {
      var done = p.milestone > i;
      seg.classList.toggle('is-complete', done);
      var fill = seg.querySelector('.cart-progress__seg-fill');
      if (fill) fill.style.width = done ? '100%' : p.seg1 + '%';
    });

    var msgEl = wrap.querySelector('.cart-progress__msg');
    var doneEl = wrap.querySelector('.cart-progress__all-done');
    if (p.milestone >= 1) {
      if (msgEl) msgEl.style.display = 'none';
      if (doneEl) doneEl.style.display = '';
    } else {
      if (msgEl) {
        msgEl.style.display = '';
        msgEl.innerHTML = 'You are <strong>' + fmt(p.remaining) + '</strong> away from <strong>free shipping</strong>!';
      }
      if (doneEl) doneEl.style.display = 'none';
    }
  }

  function normalizeProduct(prod) {
    var imgSrc = '';
    if (typeof prod.featured_image === 'string' && prod.featured_image) {
      imgSrc = prod.featured_image;
    } else if (prod.featured_image && prod.featured_image.src) {
      imgSrc = prod.featured_image.src;
    } else if (prod.images && prod.images.length && prod.images[0].src) {
      imgSrc = prod.images[0].src;
    }
    var priceCents = 0;
    if (typeof prod.price === 'number' && prod.price > 0) {
      priceCents = prod.price;
    } else if (prod.variants && prod.variants.length) {
      priceCents = Math.round(parseFloat(prod.variants[0].price) * 100);
    } else if (prod.price_min) {
      priceCents = prod.price_min;
    }
    return {
      id: prod.id,
      title: prod.title,
      imgSrc: imgSrc,
      priceCents: priceCents,
      url: prod.url || ('/products/' + prod.handle)
    };
  }

  function buildUpsellHTML(products, cartIds) {
    var filtered = products.filter(function (p) { return cartIds.indexOf(p.id) === -1; }).slice(0, 3);
    if (!filtered.length) return null;
    var html = '<h3 class="cart-upsell__heading">You may also like</h3>';
    filtered.forEach(function (prod) {
      var p = normalizeProduct(prod);
      var price = '$' + (p.priceCents / 100).toFixed(2);
      var imgSrc = p.imgSrc ? resizeImg(p.imgSrc, 110) : '';
      html += '<div class="cart-upsell__item">'
        + '<a href="' + p.url + '" class="cart-upsell__img-link">'
        + (imgSrc ? '<img src="' + imgSrc + '" alt="" loading="lazy" width="55" height="55">' : '')
        + '</a><div class="cart-upsell__info">'
        + '<a href="' + p.url + '" class="cart-upsell__name">' + p.title + '</a>'
        + '<span class="cart-upsell__price">' + price + '</span>'
        + '</div></div>';
    });
    return html;
  }

  function loadUpsell(productId, cartIds) {
    if (_upsellPending) return;
    var container = document.getElementById('CartDrawer-Upsell');
    if (!container) return;
    _upsellPending = true;

    function writeUpsell(html) {
      _upsellWriteTs = Date.now();
      container.style.display = '';
      container.innerHTML = html;
    }

    function renderOrFallback(products) {
      var html = buildUpsellHTML(products, cartIds);
      if (html) { writeUpsell(html); _upsellPending = false; return; }
      /* Fallback: best-selling products — show regardless of cart contents */
      fetch('/collections/all/products.json?limit=9&sort_by=best-selling')
        .then(function (r) { return r.json(); })
        .then(function (d) {
          var html2 = buildUpsellHTML(d.products || [], []);
          if (html2) { writeUpsell(html2); }
          else { container.style.display = 'none'; }
          _upsellPending = false;
        })
        .catch(function () { container.style.display = 'none'; _upsellPending = false; });
    }

    fetch('/recommendations/products.json?product_id=' + productId + '&limit=6&intent=complementary')
      .then(function (r) { return r.json(); })
      .then(function (data) { renderOrFallback(data.products || []); })
      .catch(function () { renderOrFallback([]); });
  }

  /* Reconciliation: net out hidden surcharge line items, add property-based accessory prices.
     This keeps the estimated total accurate regardless of whether surcharge items are stale,
     orphaned, or out of sync with the displayed property values. */
  function calcTrueTotal(items, shopifyTotal) {
    var surchargeTotal = 0, propTotal = 0;
    (items || []).forEach(function(item) {
      if (item.properties && Object.prototype.hasOwnProperty.call(item.properties, 'Accessory')) {
        surchargeTotal += item.final_line_price || 0;
      } else {
        Object.keys(item.properties || {}).forEach(function(pk) {
          if (pk.charAt(0) === '_') return;
          var m = (item.properties[pk] || '').match(/\(\+\$([0-9,]+\.?\d*)\)/);
          if (m) propTotal += Math.round(parseFloat(m[1].replace(/,/g, '')) * 100) * (item.quantity || 1);
        });
      }
    });
    return (shopifyTotal - surchargeTotal) + propTotal;
  }

  /* DOM-based total: sum data-item-base + data-item-acc from Liquid-rendered cart rows.
     More reliable than parsing /cart.js because data-item-acc is set by Liquid
     which correctly parses (+$) property values at render time. */
  function calcDomTotal() {
    var t = 0;
    document.querySelectorAll('#CartDrawer-CartItems .cart-item').forEach(function(r) {
      t += (parseInt(r.dataset.itemBase, 10) || 0) + (parseInt(r.dataset.itemAcc, 10) || 0);
    });
    return t;
  }

  var _upsellWriteTs = 0;
  var _upsellPending = false;
  var _lastTotalApply = 0;
  function applyTrueTotal(cents) {
    var el = document.querySelector('[data-hvac-cart-total]');
    if (!el) return;
    var formatted = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(cents / 100);
    _lastTotalApply = Date.now();
    el.textContent = formatted;
  }

  var _patchingLineTotals = false;
  function patchLineTotals() {
    _patchingLineTotals = true;
    document.querySelectorAll('#CartDrawer-CartItems .cart-item').forEach(function(row) {
      var acc = parseInt(row.dataset.itemAcc, 10) || 0;
      if (!acc) return;
      var base = parseInt(row.dataset.itemBase, 10) || 0;
      var priceEl = row.querySelector('.cart-item__totals .price--end');
      if (!priceEl) return;
      priceEl.textContent = new Intl.NumberFormat('en-US', {
        style: 'currency', currency: 'USD'
      }).format((base + acc) / 100);
    });
    _patchingLineTotals = false;
  }

  function refreshFromCart() {
    return fetch('/cart.js', { cache: 'no-store' })
      .then(function (r) { return r.json(); })
      .then(function (cart) {
        var items = cart.items || [];
        var domT = calcDomTotal();
        var trueTotal = domT > 0 ? domT : calcTrueTotal(items, cart.total_price);
        if (!hasUnchecked()) {
          applyProgress(trueTotal);
          applyTrueTotal(trueTotal);
        }
        setTimeout(patchLineTotals, 200);
        var cartIds = items.map(function (i) { return i.product_id; });
        var pid = items[0] ? items[0].product_id : null;
        if (pid) {
          loadUpsell(pid, cartIds);
        } else {
          var c = document.getElementById('CartDrawer-Upsell');
          if (c) c.style.display = 'none';
        }
      })
      .catch(function () {});
  }

  var _refreshTimer = null;
  function scheduleRefresh() {
    clearTimeout(_refreshTimer);
    _refreshTimer = setTimeout(refreshFromCart, 150);
  }

  function hasUnchecked() {
    return !!document.querySelector('#CartDrawer-CartItems .cart-item.is-unchecked');
  }

  function calcSelectedTotal() {
    var total = 0;
    document.querySelectorAll('#CartDrawer-CartItems .cart-item').forEach(function (row) {
      var cb = row.querySelector('.cart-item__select-input');
      if (!cb || !cb.checked) return;
      total += (parseInt(row.dataset.itemBase, 10) || 0) + (parseInt(row.dataset.itemAcc, 10) || 0);
    });
    return total;
  }

  function updateSelectedDisplay() {
    var total = calcSelectedTotal();
    var el = document.querySelector('[data-hvac-cart-total]');
    if (el) {
      _lastTotalApply = Date.now();
      el.textContent = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(total / 100);
    }
    applyProgress(total);
    var allRows = document.querySelectorAll('#CartDrawer-CartItems .cart-item');
    var checkedCount = 0;
    allRows.forEach(function (row) {
      var cb = row.querySelector('.cart-item__select-input');
      if (cb && cb.checked) checkedCount++;
    });
    var label = (checkedCount === allRows.length) ? 'Checkout' : 'Checkout Selected (' + checkedCount + ')';
    var btn = document.getElementById('CartDrawer-Checkout');
    if (btn) {
      btn.disabled = checkedCount === 0;
      btn.textContent = label;
    }
  }

  function removeAccessoryProp(itemKey, propName) {
    fetch('/cart.js')
      .then(function(r) { return r.json(); })
      .then(function(cart) {
        var item = (cart.items || []).find(function(i) { return i.key === itemKey; });
        if (!item) return Promise.reject('Item not found: ' + itemKey);
        var newProps = Object.assign({}, item.properties || {});
        newProps[propName] = '';
        return fetch('/cart/change.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
          body: JSON.stringify({ id: itemKey, properties: newProps })
        });
      })
      .then(function() {
        var cdi = document.querySelector('cart-drawer-items');
        return cdi ? cdi.onCartUpdate() : Promise.resolve();
      })
      .then(function() { scheduleRefresh(); })
      .catch(function(e) { console.error('removeAccessoryProp:', e); });
  }

  window.__hvacRemAcc = function(btn) {
    if (btn.disabled) return;
    btn.disabled = true;
    btn.style.opacity = '0.4';
    removeAccessoryProp(btn.dataset.itemKey, btn.dataset.propName);
  };

  function initSelectiveCheckout() {
    document.addEventListener('change', function (e) {
      if (!e.target.classList.contains('cart-item__select-input')) return;
      var row = e.target.closest('.cart-item');
      if (!row) return;
      row.classList.toggle('is-unchecked', !e.target.checked);
      updateSelectedDisplay();
    });

    // Capture phase: zero out unchecked items before the checkout form submits
    document.addEventListener('click', function (e) {
      var btn = e.target.closest && e.target.closest('#CartDrawer-Checkout');
      if (!btn) return;
      var unchecked = Array.from(document.querySelectorAll('#CartDrawer-CartItems .cart-item.is-unchecked'));
      if (!unchecked.length) return;
      unchecked.forEach(function (row) {
        var inp = row.querySelector('.quantity__input[name="updates[]"]');
        if (inp) inp.value = 0;
      });
    }, true);
  }

  function init() {
    refreshFromCart();

    // Re-run after any cart update (add, remove, quantity change)
    if (typeof subscribe !== 'undefined' && typeof PUB_SUB_EVENTS !== 'undefined') {
      subscribe(PUB_SUB_EVENTS.cartUpdate, scheduleRefresh);
    }

    // Also watch #CartDrawer for re-renders (e.g. after renderContents replaces innerHTML)
    var cartDrawerEl = document.getElementById('CartDrawer');
    if (cartDrawerEl) {
      new MutationObserver(function () {
        if (Date.now() - _lastTotalApply < 400) return;
        if (_patchingLineTotals) return;
        if (Date.now() - _upsellWriteTs < 800) return;
        scheduleRefresh();
      }).observe(cartDrawerEl, { childList: true, subtree: true });
    }

    initSelectiveCheckout();
  }

  /* Expose for cross-IIFE use */
  window._hvacRefresh = scheduleRefresh;
  window._hvacApplyProgress = applyProgress;
  window._hvacCalcTrue = calcTrueTotal;
  window._hvacCalcDom = calcDomTotal;

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

<script>
/* Accessory remove — surgical DOM removal, parallel-safe per-variant queue */
(function () {
  var _variantQueues = {};
  var _pending = [];

  /* Reset a removed accessory's dropdown back to its "Choose a selection…" placeholder
     so it can be picked again from scratch. Matched by variant id (the line key rotates
     on every property change) and works whether the panel is open or closed. */
  function clearRemovedSelect(variantId, propName, newProps) {
    document.querySelectorAll('[data-acc-panel]').forEach(function (p) {
      if ((p.dataset.accPanel || '').split(':')[0] !== String(variantId)) return;
      /* Keep the panel's stored props in sync so a later open reflects the removal */
      try {
        var bp = newProps ? newProps : JSON.parse(p.dataset.baseProps || '{}');
        if (!newProps) delete bp[propName];
        p.dataset.baseProps = JSON.stringify(bp);
      } catch (e) {}
      p.querySelectorAll('.cart-acc-form-select').forEach(function (sel) {
        if (sel.dataset.propName !== propName) return;
        /* Select the real placeholder option (value="" or "Choose…/None/No …"); fall back to first */
        var ph = Array.prototype.findIndex.call(sel.options, function (o) {
          return o.value === '' || /^\s*(choose|select|none|no\b)/i.test(o.text || '');
        });
        sel.selectedIndex = ph >= 0 ? ph : 0;
      });
    });
  }

  function executeRemove(variantId, propName) {
    if (window._hvacClearCartCache) window._hvacClearCartCache();
    return fetch('/cart.js', { cache: 'no-store' })
      .then(function (r) { return r.json(); })
      .then(function (cartData) {
        var matchedKeys = null;
        var item = (cartData.items || []).find(function (i) {
          if (String(i.variant_id) !== String(variantId) || !i.properties) return false;
          var mk = Object.keys(i.properties).filter(function (k) {
            return k === propName || k.trim() === String(propName).trim();
          });
          if (mk.length) { matchedKeys = mk; return true; }
          return false;
        });
        if (!item) return null;
        var newProps = Object.assign({}, item.properties);
        (matchedKeys || [propName]).forEach(function (k) { newProps[k] = ''; });
        return fetch('/cart/change.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
          body: JSON.stringify({ id: item.key, properties: newProps })
        }).then(function (r) {
          if (!r.ok) throw new Error('HTTP ' + r.status);
          return r.json();
        });
      })
      .then(function (cartResult) {
        /* Always clean up _pending regardless of whether property was found */
        _pending = _pending.filter(function (p) {
          return !(p.variantId === variantId && p.propName === propName);
        });

        if (cartResult === null) {
          /* Property was already absent — remove any stale DOM row and refresh */
          document.querySelectorAll('.cart-acc-prop').forEach(function (row) {
            var btn = row.querySelector('.cart-acc-remove');
            if (!btn || String(btn.dataset.variantId) !== String(variantId) || btn.dataset.propName !== propName) return;
            var accCell = row.closest('.cart-item-acc-cell');
            row.remove();
            var accTR = accCell ? accCell.closest('.cart-item-acc-row') : null;
            if (accCell && !accCell.querySelector('.cart-acc-prop')) {
              var hdr = accCell.querySelector('.cart-item__acc-header');
              if (hdr) hdr.remove();
              if (accTR) accTR.classList.remove('cart-item-acc-row--has-acc');
            }
          });
          clearRemovedSelect(variantId, propName);
          if (window._hvacClearCartCache) window._hvacClearCartCache();
          if (window._hvacRefresh) window._hvacRefresh();
          return;
        }

        /* Resolve the new key and remaining props from the POST response */
        var newItems = cartResult.items || [];
        var newItem  = newItems.find(function (i) { return String(i.variant_id) === String(variantId); });
        var newKey   = newItem ? newItem.key   : '';
        var newProps = newItem ? (newItem.properties || {}) : {};

        /* Surgically remove the matching accessory row(s) from the DOM */
        document.querySelectorAll('.cart-acc-prop').forEach(function (row) {
          var btn = row.querySelector('.cart-acc-remove');
          if (!btn) return;
          if (String(btn.dataset.variantId) !== String(variantId) || btn.dataset.propName !== propName) return;

          var oldKey  = btn.dataset.itemKey || '';
          var accCell = row.closest('.cart-item-acc-cell');
          row.remove();

          /* Clean up header + row class when last accessory is removed */
          var accTR = accCell ? accCell.closest('.cart-item-acc-row') : null;
          if (accCell && !accCell.querySelector('.cart-acc-prop')) {
            var hdr = accCell.querySelector('.cart-item__acc-header');
            if (hdr) hdr.remove();
            if (accTR) accTR.classList.remove('cart-item-acc-row--has-acc');
          }

          /* Update the line-item price using remaining rows in this acc cell */
          var cartItemTR = accTR ? accTR.previousElementSibling : null;
          if (cartItemTR && cartItemTR.classList.contains('cart-item')) {
            var remCents = 0;
            if (accCell) {
              accCell.querySelectorAll('.cart-acc-prop').forEach(function (r) {
                var m = r.textContent.match(/\(\+\$([0-9,]+\.?\d*)\)/);
                if (m) remCents += Math.round(parseFloat(m[1].replace(/,/g, '')) * 100);
              });
            }
            cartItemTR.dataset.itemAcc = String(remCents);
            var base    = parseInt(cartItemTR.dataset.itemBase, 10) || 0;
            var priceEl = cartItemTR.querySelector('.cart-item__totals .price--end');
            if (priceEl) {
              priceEl.textContent = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' })
                .format((base + remCents) / 100);
            }
          }

          /* Update all stale item keys in the DOM */
          if (oldKey && newKey) {
            if (accCell && accCell.dataset.forKey === oldKey) accCell.dataset.forKey = newKey;
            document.querySelectorAll('.cart-acc-toggle').forEach(function (t) {
              if (t.dataset.itemKey === oldKey) t.dataset.itemKey = newKey;
            });
            document.querySelectorAll('[data-acc-panel]').forEach(function (p) {
              if (p.dataset.accPanel !== oldKey) return;
              p.dataset.accPanel  = newKey;
              p.dataset.baseProps = JSON.stringify(newProps);
              delete p.dataset.loaded; /* force re-fetch on next open */
              /* If the panel is currently open, update its selects immediately */
              if (!p.hasAttribute('hidden')) {
                p.querySelectorAll('.cart-acc-form-select').forEach(function (sel) {
                  var pn  = sel.dataset.propName;
                  if (!pn) return;
                  sel.value = newProps[pn] || '';
                  if (!sel.value) sel.selectedIndex = 0;
                });
              }
            });
            document.querySelectorAll('.cart-acc-remove').forEach(function (b) {
              if (b.dataset.itemKey === oldKey) b.dataset.itemKey = newKey;
            });
          }
        });

        /* Reset the removed accessory's dropdown so it reads "Choose a selection…" again */
        clearRemovedSelect(variantId, propName, newProps);

        /* Update estimated total — prefer DOM-based total (data-item-acc already updated above) */
        var trueTotal = window._hvacCalcDom
          ? window._hvacCalcDom()
          : (window._hvacCalcTrue ? window._hvacCalcTrue(newItems, cartResult.total_price || 0) : (cartResult.total_price || 0));
        var totalEl = document.querySelector('[data-hvac-cart-total]');
        if (totalEl) {
          totalEl.textContent = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' })
            .format(trueTotal / 100);
        }
        if (window._hvacApplyProgress) window._hvacApplyProgress(trueTotal);

        /* Remove matching surcharge line item, then refresh footer with corrected cart total */
        (function () {
          var _orphanKeys = (cartResult.items || [])
            .filter(function (i) {
              return i.properties
                && Object.prototype.hasOwnProperty.call(i.properties, 'Accessory')
                && String(i.properties.Accessory) === String(propName)
                && String(i.properties._parent_variant || '') === String(variantId);
            })
            .map(function (i) { return i.key; });
          var _afterRemoval = _orphanKeys.length
            ? Promise.all(_orphanKeys.map(function (k) {
                return fetch('/cart/change.js', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                  body: JSON.stringify({ id: k, quantity: 0 })
                });
              }))
            : Promise.resolve();
          _afterRemoval.then(function () {
            var _cartUrl = (window.routes && window.routes.cart_url) || '/cart';
            return fetch(_cartUrl + '?section_id=cart-drawer', { cache: 'no-store' });
          }).then(function (r) { return r.text(); })
            .then(function (html) {
              var doc = new DOMParser().parseFromString(html, 'text/html');
              var tgt = document.querySelector('.cart-drawer__footer');
              var src = doc.querySelector('.cart-drawer__footer');
              if (tgt && src) tgt.replaceWith(src);
              var _fixedEl = document.querySelector('[data-hvac-cart-total]');
              if (_fixedEl) { _fixedEl.textContent = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(trueTotal / 100); }
              if (window._hvacApplyProgress) window._hvacApplyProgress(trueTotal);
            })
            .catch(function () { /* non-fatal — totals already updated above */ });
        }());

        /* Trigger refresh to keep progress bar / line totals in sync */
        if (window._hvacClearCartCache) window._hvacClearCartCache();
        if (window._hvacRefresh) window._hvacRefresh();
      });
  }

  document.addEventListener('click', function (e) {
    var t = e.target;
    var btn = (t && typeof t.closest === 'function') ? t.closest('.cart-acc-remove') : null;
    if (!btn) return;
    e.preventDefault();
    e.stopPropagation();

    var variantId = btn.dataset.variantId;
    var propName  = btn.dataset.propName;
    if (!propName) return;

    if (!variantId) {
      var rawKey = btn.dataset.itemKey || '';
      variantId = rawKey.split(':')[0];
    }
    if (!variantId) return;

    var accProp = btn.closest('.cart-acc-prop');
    if (accProp) accProp.classList.add('is-removing');
    _pending.push({ variantId: variantId, propName: propName });

    var prev = _variantQueues[variantId] || Promise.resolve();
    _variantQueues[variantId] = prev.then(function () {
      return executeRemove(variantId, propName);
    }).catch(function (err) {
      console.error('[hvac-rem-acc]', err);
      _pending = _pending.filter(function (p) {
        return !(p.variantId === variantId && p.propName === propName);
      });
      if (accProp && accProp.parentNode) accProp.classList.remove('is-removing');
    });
  }, true);
}());
</script>

