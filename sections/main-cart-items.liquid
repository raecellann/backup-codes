      /* ── Main-cart accessory chooser ── */
      .mc-acc-wrap {
        margin-top: 0.6rem;
        margin-bottom: 0.2rem;
        position: relative;
        max-width: 24rem;
      }
      .mc-acc-wrap .cart-acc-toggle {
        font-size: 1.35rem;
        padding: 0.6rem 1rem;
        white-space: nowrap;
        width: 100%;
      }
      /* Panel portaled to <body> — absolute so it scrolls with the page, no viewport clip */
      .mc-acc-panel {
        position: absolute !important;
        width: 36rem !important;
        max-width: calc(100vw - 2rem) !important;
        max-height: 65vh !important;
        overflow-y: auto !important;
        overscroll-behavior: contain;
        z-index: 9999 !important;
        border: 1px solid rgba(var(--color-foreground), 0.15) !important;
        border-radius: 8px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.18) !important;
        margin-top: 0 !important;
      }
      </style>

      <script>
        (function () {
          /* ── Parse (+$...) cents from cart item details — class-independent ── */
          function parseAccCents(row) {
            var details = row.querySelector('.cart-item__details');
            if (!details) return 0;
            /* clone so we can strip the chooser panel (its <option> text contains (+$...) strings) */
            var clone = details.cloneNode(true);
            var chooser = clone.querySelector('.mc-acc-wrap');
            if (chooser && chooser.parentNode) chooser.parentNode.removeChild(chooser);
            var text = clone.textContent;
            var cents = 0;
            var re = /\(\+\$([0-9,]+(?:\.\d{2})?)\)/g;
            var m;
            while ((m = re.exec(text)) !== null) {
              cents += Math.round(parseFloat(m[1].replace(/,/g, '')) * 100);
            }
            return cents;
          }

          function formatMoney(cents) {
            return '$' + (cents / 100).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
          }

          var HIDDEN_KEYS = ['Choose AC Installation Kit'];

          function hideBlockedProps() {
            /* dt/dd structure */
            document.querySelectorAll('.cart-item dt').forEach(function (dt) {
              var key = dt.textContent.trim().replace(/:$/, '').trim();
              var ddEl = dt.nextElementSibling;
              var val = ddEl ? ddEl.textContent.trim() : '';
              var valLow = val.toLowerCase();
              if (HIDDEN_KEYS.indexOf(key) !== -1 || valLow.slice(0, 3) === 'no ') {
                var wrapper = dt.closest('.product-option') || dt.parentElement;
                if (wrapper) wrapper.style.display = 'none';
              }
            });
            /* Direct children of [data-hulkapps-line-properties] (alternative HulkApps markup) */
            document.querySelectorAll('[data-hulkapps-line-properties] > *').forEach(function (el) {
              var text = el.textContent.trim();
              var ci = text.indexOf(':');
              if (ci === -1) return;
              var keyPart = text.slice(0, ci).trim();
              var valPart = text.slice(ci + 1).trim().toLowerCase();
              if (HIDDEN_KEYS.indexOf(keyPart) !== -1 || valPart.slice(0, 3) === 'no ') {
                el.style.display = 'none';
              }
            });
          }

          var _totalObserver = null;
          var _totalDebounce = null;

          function lockCartTotal() {
            if (document.querySelector('#main-cart-items .cart-item.is-unchecked')) return;
            var totalEl = document.querySelector('[data-hvac-footer-total][data-true-total]');
            if (!totalEl) return;
            var trueTotalCents = parseInt(totalEl.dataset.trueTotal, 10) || 0;
            var baseCartCents = parseInt(totalEl.dataset.shopifyTotal, 10) || 0;
            if (!trueTotalCents && !baseCartCents) return;
            var correctText = trueTotalCents
              ? formatMoney(trueTotalCents)
              : formatMoney(baseCartCents);
            if (totalEl.textContent.trim() === correctText) return;
            totalEl.textContent = correctText;
          }

          function calcMainCartSelectedTotal() {
            var total = 0;
            document.querySelectorAll('#main-cart-items .cart-item').forEach(function (row) {
              var cb = row.querySelector('.cart-item__select-input');
              if (!cb || !cb.checked) return;
              var priceEl = row.querySelector('[data-hulkapps-line-price]');
              if (!priceEl) return;
              var baseCents = parseInt(priceEl.dataset.basePrice, 10) || 0;
              var accCents = parseAccCents(row);
              total += baseCents + accCents;
            });
            return total;
          }

          function updateMainCartSelectedDisplay() {
            var totalEl = document.querySelector('[data-hvac-footer-total][data-true-total]');
            if (!totalEl) return;
            var hasUnchecked = !!document.querySelector('#main-cart-items .cart-item.is-unchecked');
            if (hasUnchecked) {
              totalEl.textContent = formatMoney(calcMainCartSelectedTotal());
            } else {
              lockCartTotal();
            }
          }

          var _mainCartSelectiveInited = false;
          function initMainCartSelectiveCheckout() {
            if (_mainCartSelectiveInited) return;
            _mainCartSelectiveInited = true;

            document.addEventListener('change', function (e) {
              if (!e.target.classList.contains('cart-item__select-input')) return;
              var row = e.target.closest('#main-cart-items .cart-item');
              if (!row) return;
              row.classList.toggle('is-unchecked', !e.target.checked);
              updateMainCartSelectedDisplay();
            });

            document.addEventListener('click', function (e) {
              var btn = e.target.closest && e.target.closest('#checkout');
              if (!btn) return;
              var unchecked = Array.from(document.querySelectorAll('#main-cart-items .cart-item.is-unchecked'));
              if (!unchecked.length) return;
              unchecked.forEach(function (row) {
                var inp = row.querySelector('.quantity__input[name="updates[]"]');
                if (inp) inp.value = 0;
              });
            }, true);
          }

          function startFooterWatcher() {
            var footer = document.getElementById('main-cart-footer');
            if (!footer) return;
            if (_totalObserver) _totalObserver.disconnect();
            _totalObserver = new MutationObserver(function () {
              clearTimeout(_totalDebounce);
              _totalDebounce = setTimeout(lockCartTotal, 60);
            });
            _totalObserver.observe(footer, { childList: true, subtree: true, characterData: true });
          }

          function updateMainCartProgress() {
            var wrap = document.getElementById('main-cart-progress-wrap');
            if (!wrap) return;
            var totalEl = document.querySelector('[data-hvac-footer-total][data-true-total]');
            if (!totalEl) return;
            var cents = parseInt(totalEl.dataset.trueTotal, 10) || 0;
            var FS = 50000;
            var milestone, seg1, remaining = 0;
            if (cents >= FS) {
              milestone = 1; seg1 = 100;
            } else {
              milestone = 0; seg1 = Math.min(100, Math.round(cents / FS * 100));
              remaining = FS - cents;
            }
            wrap.querySelectorAll('.cart-progress__step').forEach(function (s, i) {
              s.classList.toggle('is-done', milestone > i);
            });
            wrap.querySelectorAll('.cart-progress__seg').forEach(function (seg, i) {
              var done = milestone > i;
              seg.classList.toggle('is-complete', done);
              var fill = seg.querySelector('.cart-progress__seg-fill');
              if (fill) fill.style.width = done ? '100%' : seg1 + '%';
            });
            var msgEl = wrap.querySelector('.cart-progress__msg');
            var doneEl = wrap.querySelector('.cart-progress__all-done');
            if (milestone >= 1) {
              if (msgEl) msgEl.style.display = 'none';
              if (doneEl) doneEl.style.display = '';
            } else {
              var rem_d = Math.floor(remaining / 100);
              var rem_c = String(remaining % 100).padStart(2, '0');
              if (msgEl) {
                msgEl.style.display = '';
                msgEl.innerHTML = 'You are <strong>$' + rem_d + '.' + rem_c + '</strong> away from <strong>free shipping</strong>!';
              }
              if (doneEl) doneEl.style.display = 'none';
            }
          }

          function applyCartTotal(grandAccCents) {
            lockCartTotal();
            updateMainCartProgress();
          }

          function updateAccTotals() {
            var grandAccCents = 0;
            document.querySelectorAll('.cart-item').forEach(function (row) {
              var accCents = parseAccCents(row);
              grandAccCents += accCents;
              if (accCents <= 0) return;
              row.querySelectorAll('[data-hulkapps-line-price]').forEach(function (el) {
                var baseCents = parseInt(el.dataset.basePrice, 10);
                if (!baseCents) {
                  var ourLast = el.dataset.ourPrice;
                  var cur = el.textContent.trim();
                  if (ourLast && cur === ourLast) return;
                  baseCents = Math.round(parseFloat(cur.replace(/[^0-9.]/g, '')) * 100) || 0;
                }
                if (!baseCents) return;
                var newText = formatMoney(baseCents + accCents);
                el.textContent = newText;
                el.dataset.ourPrice = newText;
              });
            });
            applyCartTotal(grandAccCents);
          }

          var _isUpdating = false;
          var _debounce = null;
          var _mainObs = null;

          function applyAll() {
            _isUpdating = true;
            hideBlockedProps();
            updateAccTotals();
            setTimeout(function () { _isUpdating = false; }, 80);
          }

          function startWatching() {
            var el = document.getElementById('main-cart-items');
            if (!el) return;
            if (_mainObs) _mainObs.disconnect();
            _mainObs = new MutationObserver(function () {
              if (_isUpdating) return;
              clearTimeout(_debounce);
              _debounce = setTimeout(applyAll, 80);
            });
            _mainObs.observe(el, { childList: true, subtree: true, characterData: true });
          }

          function init() {
            applyAll();
            startWatching();
            startFooterWatcher();
            lockCartTotal();
            initMainCartSelectiveCheckout();
          }

          document.addEventListener('DOMContentLoaded', function () {
            init();
            setTimeout(init, 500);
            setTimeout(init, 1500);
          });

          window.addEventListener('load', init);

          document.addEventListener('cart-update', function () {
            if (_mainObs) { _mainObs.disconnect(); _mainObs = null; }
            if (_totalObserver) { _totalObserver.disconnect(); _totalObserver = null; }
            _isUpdating = false;
            document.querySelectorAll('[data-hulkapps-line-price]').forEach(function (el) {
              delete el.dataset.ourPrice;
            });
            setTimeout(init, 300);
            setTimeout(lockCartTotal, 800);
            setTimeout(lockCartTotal, 1600);
          });

          /* ── Re-render main-cart sections after accessory save (called by cart-drawer saveAccessories) ── */
          window._hvacRefresh = function () {
            var sItems = document.getElementById('main-cart-items');
            var sFooter = document.getElementById('main-cart-footer');
            if (!sItems) return;
            var ids = [];
            if (sItems.dataset.id) ids.push(sItems.dataset.id);
            if (sFooter && sFooter.dataset.id) ids.push(sFooter.dataset.id);
            if (!ids.length) return;
            fetch('/cart?sections=' + ids.join(',') + '&sections_url=' + encodeURIComponent(window.location.pathname), { cache: 'no-store' })
              .then(function (r) { return r.json(); })
              .then(function (data) {
                var parser = new DOMParser();
                var sid = sItems.dataset.id;
                if (sid && data[sid]) {
                  var doc1 = parser.parseFromString(data[sid], 'text/html');
                  var src1 = doc1.querySelector('.js-contents');
                  var dest1 = sItems.querySelector('.js-contents');
                  if (src1 && dest1) dest1.innerHTML = src1.innerHTML;
                }
                if (sFooter) {
                  var fid = sFooter.dataset.id;
                  if (fid && data[fid]) {
                    var doc2 = parser.parseFromString(data[fid], 'text/html');
                    var src2 = doc2.querySelector('.js-contents');
                    var dest2 = sFooter.querySelector('.js-contents');
                    if (src2 && dest2) dest2.innerHTML = src2.innerHTML;
                  }
                }
                document.dispatchEvent(new CustomEvent('cart-update'));
              })
              .catch(function () {});
          };

          /* ── Accessory delete — parallel-safe, serialised per variant ── */
          var _variantQueues = {};  // variantId → Promise chain (serialises same-item deletes)
          var _pendingDeletes = []; // [{variantId, accKey}] currently in-flight

          /* Re-apply fades after any re-render so in-flight rows stay faded */
          function applyPendingFades() {
            document.querySelectorAll('.cart-item__acc-row').forEach(function (r) {
              var pending = _pendingDeletes.some(function (pd) {
                return pd.variantId === r.dataset.variantId && pd.accKey === r.dataset.accKey;
              });
              if (pending) {
                r.style.opacity = '0.35';
                r.style.pointerEvents = 'none';
              }
            });
          }

          function rerenderCartSections(data) {
            var parser = new DOMParser();
            var cartItemsEl = document.getElementById('main-cart-items');
            var cartFooterEl = document.getElementById('main-cart-footer');
            var rerendered = false;
            if (data && data.sections) {
              if (cartItemsEl && cartItemsEl.dataset.id && data.sections[cartItemsEl.dataset.id]) {
                var doc1 = parser.parseFromString(data.sections[cartItemsEl.dataset.id], 'text/html');
                var src1 = doc1.querySelector('.js-contents');
                var dest1 = cartItemsEl.querySelector('.js-contents');
                if (src1 && dest1) { dest1.innerHTML = src1.innerHTML; rerendered = true; }
              }
              if (cartFooterEl && cartFooterEl.dataset.id && data.sections[cartFooterEl.dataset.id]) {
                var doc2 = parser.parseFromString(data.sections[cartFooterEl.dataset.id], 'text/html');
                var src2 = doc2.querySelector('.js-contents');
                var dest2 = cartFooterEl.querySelector('.js-contents');
                if (src2 && dest2) dest2.innerHTML = src2.innerHTML;
              }
            }
            if (!rerendered) {
              var cartCustomEl = document.querySelector('cart-items');
              if (cartCustomEl && typeof cartCustomEl.onCartUpdate === 'function') {
                var p = cartCustomEl.onCartUpdate();
                if (p && p.then) p.then(applyPendingFades);
              }
            }
            applyPendingFades(); // re-fade any still-pending rows after DOM swap
            document.dispatchEvent(new CustomEvent('cart-update'));
          }

          function executeAccRemove(variantId, accKey) {
            return fetch('/cart.js')
              .then(function (r) { return r.json(); })
              .then(function (cartData) {
                /* Always resolve by variantId + accKey so stale keys never block */
                var item = cartData.items.find(function (i) {
                  return String(i.variant_id) === String(variantId) &&
                    i.properties && Object.prototype.hasOwnProperty.call(i.properties, accKey);
                });
                if (!item) return null; // already removed — nothing to do
                var props = Object.assign({}, item.properties);
                delete props[accKey];
                var cartItemsEl = document.getElementById('main-cart-items');
                var cartFooterEl = document.getElementById('main-cart-footer');
                var sections = [];
                if (cartItemsEl && cartItemsEl.dataset.id) sections.push(cartItemsEl.dataset.id);
                if (cartFooterEl && cartFooterEl.dataset.id) sections.push(cartFooterEl.dataset.id);
                return fetch('/cart/change.js', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ id: item.key, properties: props, sections: sections, sections_url: window.location.pathname })
                }).then(function (r) { return r.json(); });
              })
              .then(function (data) {
                _pendingDeletes = _pendingDeletes.filter(function (pd) {
                  return !(pd.variantId === variantId && pd.accKey === accKey);
                });
                rerenderCartSections(data);
              });
          }

          document.addEventListener('click', function (e) {
            var btn = e.target.closest('.cart-item__acc-remove');
            if (!btn) return;
            var row = btn.closest('.cart-item__acc-row');
            if (!row) return;
            var accKey = row.dataset.accKey;
            var variantId = row.dataset.variantId;
            if (!accKey || !variantId) return;

            /* Immediate visual feedback on THIS row only */
            row.style.opacity = '0.35';
            row.style.pointerEvents = 'none';
            _pendingDeletes.push({ variantId: variantId, accKey: accKey });

            /* Chain onto same-variant queue; different variants run in parallel */
            var prev = _variantQueues[variantId] || Promise.resolve();
            _variantQueues[variantId] = prev.then(function () {
              return executeAccRemove(variantId, accKey);
            }).catch(function (err) {
              console.error('Acc remove failed', err);
              _pendingDeletes = _pendingDeletes.filter(function (pd) {
                return !(pd.variantId === variantId && pd.accKey === accKey);
              });
              row.style.opacity = '';
              row.style.pointerEvents = '';
            });
          });
        })();
      </script>
      <p
        class="visually-hidden"
        id="shopping-cart-line-item-status"
        aria-live="polite"
        aria-hidden="true"
        role="status"
      >
        {{ 'accessibility.loading' | t }}
      </p>
    </form>
  </div>
</cart-items>

