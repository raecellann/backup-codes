          }
          .main-cart-top-row .main-cart-progress-wrap .cart-progress__bar-wrap,
          .main-cart-top-row .main-cart-progress-wrap .cart-progress__seg {
            width: 100%;
          }
          .cart-continue-btn {
            grid-column: unset;
            justify-self: unset;
            align-self: flex-end;
            height: 40px;
