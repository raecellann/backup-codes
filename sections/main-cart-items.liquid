        /* Selective checkout — main cart */
        .cart-main__media-wrap {
          display: flex;
          align-items: flex-start;
          gap: 0.6rem;
        }
        .cart-main__image-group {
          flex: 1;
          min-width: 0;
        }
        .cart-item__select {
          display: flex;
