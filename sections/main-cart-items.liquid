          flex-shrink: 0;
          padding-top: 0.3rem;
          cursor: pointer;
          line-height: 0;
        }
        .cart-item__select-input {
          -webkit-appearance: none;
          appearance: none;
          width: 2rem !important;
          height: 2rem !important;
          border: 2px solid rgba(var(--color-foreground), 0.3);
          border-radius: 4px;
          cursor: pointer;
          position: relative;
          background: transparent;
          flex-shrink: 0;
          transition: border-color 0.15s, background-color 0.15s;
          margin: 0 !important;
          display: block !important;
        }
        .cart-item__select-input:checked {
          border-color: #2a74af;
          background-color: #2a74af;
        }
        .cart-item__select-input:checked::after {
          content: '';
          position: absolute;
          left: 3px;
          top: 0;
          width: 7px;
          height: 11px;
          border: 2.5px solid white;
          border-top: none;
          border-left: none;
          transform: rotate(45deg);
        }
        .cart-item__select-input:focus-visible {
          outline: 2px solid #2a74af;
          outline-offset: 2px;
        }
        #main-cart-items .cart-item.is-unchecked {
          opacity: 0.35;
          transition: opacity 0.2s;
        }
        #main-cart-items .cart-item.is-unchecked td:not(.cart-item__media),
        #main-cart-items .cart-item.is-unchecked .cart-main__image-group,
        #main-cart-items .cart-item.is-unchecked .cart-main__image-group * {
          pointer-events: none;
        }
        #main-cart-items .cart-item.is-unchecked .cart-item__select {
          opacity: 1;
          pointer-events: auto;
        }

        /* Total price per item */
        .cart-item__totals .price--end {
          font-weight: 700;
        }

        /* Reduce "Your cart" title top padding */
        cart-items.section-{{ section.id }}-padding {
