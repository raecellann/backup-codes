        }

        /* Tighten the title-to-progress-bar gap */
        .title-wrapper-with-link {
          margin-bottom: 0.6rem !important;
        }

        /* Hide the inline checkout bar — checkout button lives in cart footer */
        .cart-checkout-bar {
