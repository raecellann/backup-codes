{%- assign hvac_user_item_count = 0 -%}
{%- for item in cart.items -%}
  {%- unless item.product.handle == 'hvac-accessory-surcharge' -%}
    {%- assign hvac_user_item_count = hvac_user_item_count | plus: item.quantity -%}
  {%- endunless -%}
{%- endfor -%}

{% if cart == empty or hvac_user_item_count == 0 %}
  <span class="svg-wrapper">{{ 'icon-cart-empty.svg' | inline_asset_content }}</span>
{% else %}
  <span class="svg-wrapper">{{ 'icon-cart.svg' | inline_asset_content }}</span>
{% endif %}

<span class="visually-hidden">{{ 'templates.cart.cart' | t }}</span>
{%- if hvac_user_item_count > 0 -%}
  <div class="cart-count-bubble">
    {%- if hvac_user_item_count < 100 -%}
      <span aria-hidden="true">{{ hvac_user_item_count }}</span>
    {%- endif -%}
    <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: hvac_user_item_count }}</span>
  </div>
{%- endif -%}
